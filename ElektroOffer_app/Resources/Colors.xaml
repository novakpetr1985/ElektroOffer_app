<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F6F8"/>
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#EEF2F6"/>
    <SolidColorBrush x:Key="AppBorderBrush" Color="#D6DDE6"/>
    <SolidColorBrush x:Key="AppTextBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#667085"/>
    <SolidColorBrush x:Key="AppInputBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AppInputTextBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="AppButtonBrush" Color="#F3F4F6"/>
