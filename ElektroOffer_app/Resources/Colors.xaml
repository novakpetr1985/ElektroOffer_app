<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================== -->
    <!-- 🎨 BARVY APLIKACE                                     -->
    <!-- ===================================================== -->
    <!-- 👉 Základní paleta barev pro celou aplikaci           -->
    <!-- 👉 Používá se ve Styles.xaml                          -->
    <!-- ===================================================== -->

    <!-- Primární barva (např. tlačítka, zvýraznění) -->
    <Color x:Key="PrimaryColor">#FF007ACC</Color>

    <!-- Sekundární barva (např. pozadí panelů) -->
    <Color x:Key="SecondaryColor">#FF2D2D30</Color>

    <!-- Barva textu -->
    <Color x:Key="TextColor">#FFFFFFFF</Color>

    <!-- Barva pozadí okna -->
    <Color x:Key="WindowBackgroundColor">#FF1E1E1E</Color>
</ResourceDictionary>
