KONTROLA

SELECT m.Name, c.Name AS Kategorie, s.Name AS Dodavatel, mp.SupplierCode, mp.Price
FROM MaterialPrices mp
JOIN Materials m ON m.Id = mp.MaterialId
JOIN Categories c ON c.Id = m.CategoryId
JOIN Suppliers s ON s.Id = mp.SupplierId
ORDER BY m.Name, s.Name;

-- Ověření, že žádný materiál nezůstal bez kategorie
SELECT Name FROM Materials WHERE CategoryId IS NULL;
-- Očekávaný výsledek: 0 řádků

-- Ověření, že žádný materiál nemá jen jednu cenu místo dvou
SELECT m.Name, COUNT(mp.Id) AS PocetCen
FROM Materials m
LEFT JOIN MaterialPrices mp ON mp.MaterialId = m.Id
GROUP BY m.Name
HAVING COUNT(mp.Id) &lt;&gt; 2;
-- Očekávaný výsledek: 0 řádků (každý materiál má přesně 2 ceny - ELKOV + EMAS)
