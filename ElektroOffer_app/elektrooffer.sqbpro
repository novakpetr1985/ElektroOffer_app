DELETE FROM PriceCatalog;
DELETE FROM sqlite_sequence WHERE name = 'PriceCatalog';

DROP TABLE IF EXISTS PriceCatalog;

CREATE TABLE PriceCatalog (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    TaskId INTEGER NOT NULL,
    BasePrice REAL NOT NULL,
    SpecificationId INTEGER NOT NULL,
	Unit TEXT,
    MaterialId INTEGER NOT NULL,
    BaseMaterialId INTEGER NOT NULL,
    PositionId INTEGER NOT NULL,
    MaterialCoef REAL,
    PositionCoef REAL
);

DELETE FROM PriceCatalog;
INSERT INTO PriceCatalog
(
    TaskId,
    BasePrice,
    SpecificationId,
    Unit,
    MaterialId,
    BaseMaterialId,
    PositionId,
    MaterialCoef,
    PositionCoef
)
SELECT
    t.Id,
    t.BasePrice,
    s.Id,
    s.Unit,
    m.Id,
    b.Id,
    p.Id,
    b.MaterialCoef,
    p.PositionCoef
FROM Tasks t
CROSS JOIN Specifications s
CROSS JOIN Materials m
CROSS JOIN BaseMaterials b
CROSS JOIN Positions p;

----------------------------------------------------- 
 
SELECT * FROM BaseMAterials;

UPDATE BaseMAterials
SET MaterialCoef = CASE ID
    WHEN 1 THEN 1
    WHEN 2 THEN 1.2
	WHEN 3 THEN 1.4
	WHEN 4 THEN 1.5
	WHEN 5 THEN 2
	WHEN 6 THEN 2.5
	WHEN 7 THEN 1
END
WHERE ID IN (1, 2, 3, 4, 5, 6, 7);


SELECT * FROM Positions;

UPDATE Positions
SET PositionCoef = CASE ID
    WHEN 1 THEN 1
    WHEN 2 THEN 1.1
	WHEN 3 THEN 1.2
	WHEN 4 THEN 1.5

END
WHERE ID IN (1, 2, 3, 4);


SELECT * FROM Tasks;

INSERT INTO Tasks (Name, BasePrice) VALUES ('Vrtání otvor', 180);

UPDATE Tasks SET BasePrice = 80 WHERE Id = 1;
UPDATE Tasks SET BasePrice = 60 WHERE Id = 2;
UPDATE Tasks SET BasePrice = 80 WHERE Id = 3;


SELECT * FROM Specifications;


UPDATE Specifications SET Unit = 'm'  WHERE Id = 1;
UPDATE Specifications SET Unit = 'ks' WHERE Id = 2;
UPDATE Specifications SET Unit = 'ks' WHERE Id = 3;
UPDATE Specifications SET Unit = 'ks' WHERE Id = 4;

--------------------------------------
SELECT * FROM PriceItems;

DELETE FROM PriceItems;

INSERT INTO PriceItems
(
    BasePrice,
    Unit,
    Task,
    Specification,
    Material,
    Location,
    MaterialCoef,
    PositionCoef
)
SELECT
    pm.BasePrice,
    pm.Unit,
    t.Name,
    s.Name,
    bm.Name,
    p.Name,
    pm.MaterialCoef,
    pm.PositionCoef
FROM PriceCatalog pm
JOIN Tasks t ON t.Id = pm.TaskId
JOIN Specifications s ON s.Id = pm.SpecificationId
JOIN BaseMaterials bm ON bm.Id = pm.BaseMaterialId
JOIN Positions p ON p.Id = pm.PositionId;


UPDATE Tasks
SET name = 'Vrtání průraz'
WHERE Id = 2;



