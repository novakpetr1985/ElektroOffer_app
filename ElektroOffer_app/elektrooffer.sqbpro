DELETE FROM PriceItems;
DELETE FROM PriceCatalog;
DELETE FROM sqlite_sequence WHERE name = 'PriceItems';
DELETE FROM sqlite_sequence WHERE name = 'PriceCatalog';

INSERT INTO PriceCatalog
(
    TaskId,
    BasePrice,
    SpecificationId,
    Unit,
    MaterialId,
    BaseMaterialId,
    PositionId,
    MaterialCoef,
    PositionCoef
)
SELECT
    t.Id,
    t.BasePrice,
    s.Id,
    s.Unit,
    m.Id,
    b.Id,
    p.Id,
    b.MaterialCoef,
    p.PositionCoef
FROM Tasks t
CROSS JOIN Specifications s
CROSS JOIN Materials m
CROSS JOIN BaseMaterials b
CROSS JOIN Positions p;

INSERT INTO PriceItems
(
    BasePrice,
    Unit,
    Task,
    Specification,
    Material,
    Location,
    MaterialCoef,
    PositionCoef
)
SELECT
    pm.BasePrice,
    pm.Unit,
    t.Name,
    s.Name,
    bm.Name,
    p.Name,
    pm.MaterialCoef,
    pm.PositionCoef
FROM PriceCatalog pm
JOIN Tasks t ON t.Id = pm.TaskId
JOIN Specifications s ON s.Id = pm.SpecificationId
JOIN BaseMaterials bm ON bm.Id = pm.BaseMaterialId
JOIN Positions p ON p.Id = pm.PositionId;



