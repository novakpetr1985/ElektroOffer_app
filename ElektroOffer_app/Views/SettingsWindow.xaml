<Window x:Class="ElektroOffer_app.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nastavení"
        Width="760"
        Height="460"
        MinWidth="680"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10">
            <StackPanel>
                <TextBlock Text="Nastavení"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="4,2,4,14"/>
                <Border Background="{DynamicResource AppSurfaceAltBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10">
                    <TextBlock Text="Vzhled"
                               FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22">
            <StackPanel>
                <TextBlock Text="Vzhled aplikace"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Vyber režim prostředí pro hlavní okno a navazující dialogy."
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Margin="0,0,0,22"/>

                <RadioButton Content="Dle nastavení systému"
                             GroupName="Theme"
                             IsChecked="{Binding IsSystemTheme}"
                             Margin="0,0,0,12"/>
                <RadioButton Content="Světlý režim"
                             GroupName="Theme"
                             IsChecked="{Binding IsLightTheme}"
                             Margin="0,0,0,12"/>
                <RadioButton Content="Tmavý režim"
                             GroupName="Theme"
                             IsChecked="{Binding IsDarkTheme}"
                             Margin="0,0,0,22"/>

                <Border Background="{DynamicResource AppSurfaceAltBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="12">
                    <TextBlock Text="Změna se uloží automaticky a použije se i při dalším spuštění aplikace."
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
