<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="1200"
        Width="1000">

    <DockPanel LastChildFill="True"
               Background="{DynamicResource AppBackgroundBrush}">

        <!-- MENU -->
        <Menu DockPanel.Dock="Top">

            <MenuItem Header="_Soubor">

                <MenuItem Header="_Nový projekt"
                          InputGestureText="Ctrl+N"
                          Command="{Binding NewProjectCommand}" />

                <Separator/>

                <MenuItem Header="_Otevřít..."
                          InputGestureText="Ctrl+O"
                          Command="{Binding LoadCommand}" />

                <Separator/>

                <MenuItem Header="_Uložit"
                          InputGestureText="Ctrl+S"
                          Command="{Binding SaveCommand}" />

                <MenuItem Header="Uložit _jako..."
                          InputGestureText="Ctrl+Shift+S"
                          Command="{Binding SaveAsCommand}" />

                <MenuItem Header="_Tisk"
                          InputGestureText="Ctrl+P"
                          Command="{Binding PrintCommand}" />

                <MenuItem Header="_Fakturace"
                          Command="{Binding InvoiceCommand}" />

                <Separator/>

                <MenuItem Header="_Importovat katalog z Excelu..."
                          Command="{Binding ImportCatalogCommand}" />

                <MenuItem Header="_Konec"
                          InputGestureText="Alt+F4"
                          Command="{Binding ExitCommand}" />

            </MenuItem>

            <MenuItem Header="_Možnosti">
                <MenuItem Header="_Nastavení..."
                          Command="{Binding SettingsCommand}" />
            </MenuItem>

            <MenuItem Header="_Nápověda">
                <MenuItem Header="_O aplikaci..."
                          Command="{Binding AboutCommand}" />
            </MenuItem>

        </Menu>

        <!-- TOOLBAR -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>

                <Button Content="🆕 Nový"
                        ToolTip="Nový projekt (Ctrl+N)"
                        Command="{Binding NewProjectCommand}"
                        Margin="2"/>

                <Separator/>

                <Button Content="📂 Otevřít"
                        ToolTip="Načíst projekt (Ctrl+O)"
                        Command="{Binding LoadCommand}"
                        Margin="2"/>

                <Button Content="💾 Uložit"
                        ToolTip="Uložit projekt (Ctrl+S)"
                        Command="{Binding SaveCommand}"
                        Margin="2"/>

                <Button Content="💾 Uložit jako"
                        ToolTip="Uložit jako... (Ctrl+Shift+S)"
                        Command="{Binding SaveAsCommand}"
                        Margin="2"/>

                <Button Content="🖨️ Tisk"
                        ToolTip="Tisk"
                        Command="{Binding PrintCommand}"
                        Margin="2"/>

                <Button Content="Fakturace"
                        ToolTip="Vytvořit fakturu z detailního rozpočtu"
                        Command="{Binding InvoiceCommand}"
                        Margin="2"/>

            </ToolBar>
        </ToolBarTray>

        <!-- STATUS BAR -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- HLAVNÍ OBSAH -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource AppBackgroundBrush}">
            <Grid Margin="20"
                  Background="{DynamicResource AppBackgroundBrush}">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ========================= -->
                <!-- 🛠️ PRÁCE -->
                <!-- ========================= -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                        
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🛠️ PRÁCE"
                        FontSize="18"
                        FontWeight="Bold"/>
                        <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Command="{Binding AddWorkItemCommand}"
                        ToolTip="Přidat řádek práce"/>

                </StackPanel>

                    <!-- ================================ -->
                    <!-- 🛠️ PRÁCE - HLAVIČKA TABULKY -->
                    <!-- ========================= -->
                    <Grid Margin="0,8,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>  <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                            <ColumnDefinition Width="150"/> <!-- ÚKON -->
                            <ColumnDefinition Width="150"/> <!-- UPŘESNĚNÍ -->
                            <ColumnDefinition Width="150"/> <!-- PODKLAD -->
                            <ColumnDefinition Width="120"/> <!-- UMÍSTĚNÍ -->
                            <ColumnDefinition Width="60"/>  <!-- MNOŽSTVÍ -->
                            <ColumnDefinition Width="40"/>  <!-- 🔥 MJ -->
                            <ColumnDefinition Width="80"/>  <!-- 💰 CENA PRÁCE -->
                            <ColumnDefinition Width="70"/>  <!-- 🔄 RESET ŘÁDKU -->
                            <ColumnDefinition Width="60"/>  <!-- 💸 SLEVA -->
                        </Grid.ColumnDefinitions>

                        <!-- ÚKON -->
                        <TextBlock Grid.Column="1"
                                   Text="Úkon"
                                   FontWeight="Bold"/>

                        <!-- UPŘESNĚNÍ -->
                        <TextBlock Grid.Column="2"
                                   Text="Upřesnění"
                                   FontWeight="Bold"/>

                        <!-- PODKLAD -->
                        <TextBlock Grid.Column="3"
                                   Text="Podklad"
                                   FontWeight="Bold"/>

                        <!-- UMÍSTĚNÍ -->
                        <TextBlock Grid.Column="4"
                                   Text="Umístění"
                                   FontWeight="Bold"/>

                        <!-- MNOŽSTVÍ -->
                        <TextBlock Grid.Column="5"
                                   Text="Množství"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"/>

                        <!-- 🔥 MJ -->
                        <TextBlock Grid.Column="6"
                                   Text="MJ"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>

                        <!-- 💰 CENA PRÁCE -->
                        <TextBlock Grid.Column="7"
                                   Text="Po slevě"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"/>

                        <!-- 💸 SLEVA -->
                        <TextBlock Grid.Column="9"
                                   Text="Sleva %"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                    </Grid>

                    <!-- ========================= -->
                    <!-- 🛠️ PRÁCE - ITEM LIST -->
                    <!-- ========================= -->
                    <ItemsControl ItemsSource="{Binding WorkCalcItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,5">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="35"/>  <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                                            <ColumnDefinition Width="150"/> <!-- ÚKON -->
                                            <ColumnDefinition Width="150"/> <!-- UPŘESNĚNÍ -->
                                            <ColumnDefinition Width="150"/> <!-- PODKLAD -->
                                            <ColumnDefinition Width="120"/> <!-- UMÍSTĚNÍ -->
                                            <ColumnDefinition Width="60"/>  <!-- MNOŽSTVÍ -->
                                            <ColumnDefinition Width="40"/>  <!-- 🔥 MJ -->
                                            <ColumnDefinition Width="80"/>  <!-- 💰 CENA PRÁCE -->
                                            <ColumnDefinition Width="70"/>  <!-- 🔄 RESET ŘÁDKU -->
                                            <ColumnDefinition Width="60"/>  <!-- 💸 SLEVA -->
                                        </Grid.ColumnDefinitions>

                                        <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                                        <Button Grid.Column="0"
                                                Content="−"
                                                Width="25"
                                                Height="25"
                                                Background="{DynamicResource AppDangerBrush}"
                                                Foreground="White"
                                                Command="{Binding DataContext.DeleteWorkItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Smazat řádek"/>

                                        <!-- ÚKON -->
                                        <ComboBox Grid.Column="1"
                                                ItemsSource="{Binding DataContext.WorkTasks, RelativeSource={RelativeSource AncestorType=Window}}"
                                                SelectedItem="{Binding SelectedWorkTask, Mode=TwoWay}"/>

                                        <!-- UPŘESNĚNÍ -->
                                        <ComboBox Grid.Column="2"
                                                IsEnabled="{Binding CanSelectWorkSpecification}"
                                                ItemsSource="{Binding AvailableWorkSpecifications}"
                                                SelectedItem="{Binding SelectedWorkSpecification, Mode=TwoWay}"/>

                                        <!-- PODKLAD -->
                                        <ComboBox Grid.Column="3"
                                                IsEnabled="{Binding CanSelectBaseMaterial}"
                                                ItemsSource="{Binding DataContext.BaseMaterialsList, RelativeSource={RelativeSource AncestorType=Window}}"
                                                SelectedItem="{Binding SelectedBaseMaterial, Mode=TwoWay}"/>

                                        <!-- UMÍSTĚNÍ -->
                                        <ComboBox Grid.Column="4"
                                                IsEnabled="{Binding CanSelectWorkPosition}"
                                                ItemsSource="{Binding DataContext.WorkPositionsList, RelativeSource={RelativeSource AncestorType=Window}}"
                                                SelectedItem="{Binding SelectedWorkPosition, Mode=TwoWay}"/>

                                        <!-- MNOŽSTVÍ -->
                                        <TextBox Grid.Column="5"
                                                TextAlignment="Right"
                                                Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                                        <!-- 🔥 MJ -->
                                        <TextBlock Grid.Column="6"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                TextAlignment="Center"
                                                Foreground="{DynamicResource AppMutedTextBrush}"
                                                Text="{Binding WorkUnit}"/>

                                        <!-- 💰 CENA PRÁCE -->
                                        <TextBlock Grid.Column="7"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource AppTextBrush}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                TextAlignment="Right"
                                                Text="{Binding Total, StringFormat={}{0:N0} Kč}"/>

                                        <!-- 🔄 RESET ŘÁDKU -->
                                        <Button Grid.Column="8"
                                                Content="SMAZAT"
                                                Background="{DynamicResource AppAccentBrush}"
                                                Foreground="White"
                                                Command="{Binding DataContext.ResetWorkItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Vymazat data řádku"/>

                                        <!-- 💸 SLEVA -->
                                        <StackPanel Grid.Column="9"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">

                                            <CheckBox IsChecked="{Binding IsDiscountEnabled}"
                                                    VerticalAlignment="Center"/>

                                            <TextBox Width="25"
                                                    Margin="5,0,0,0"
                                                    TextAlignment="Right"
                                                    IsEnabled="{Binding IsDiscountEnabled}"
                                                    Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Text="%"
                                                    Margin="2,0,0,0"
                                                    Foreground="{DynamicResource AppMutedTextBrush}"/>
                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ========================= -->
                    <!-- 🛠️ SOUČET PRÁCE -->
                    <!-- ========================= -->
                    <Border Margin="0,10,0,0"
                            Padding="10"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Součet práce"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AppSuccessBrush}"/>

                            <TextBlock Grid.Column="1"
                                    Text="{Binding WorkTotal, StringFormat={}{0:N0} Kč}"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AppSuccessBrush}"
                                    HorizontalAlignment="Right"
                                    TextAlignment="Right"/>

                        </Grid>

                    </Border>

                </StackPanel>

                <!-- ========================= -->
                <!-- 🧱 MATERIÁL -->
                <!-- ========================= -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧱 MATERIÁL"
                                FontSize="18"
                                FontWeight="Bold"/>
                        <Button Content="+"
                                Width="30"
                                Margin="10,0,0,0"
                                Command="{Binding AddMaterialItemCommand}"
                                ToolTip="Přidat řádek materiálu"/>
                </StackPanel>

                    <!-- ================================ -->
                    <!-- 🧱 MATERIÁL - HLAVIČKA TABULKY -->
                    <!-- ================================ -->
                    <Grid Margin="0,8,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>  <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                            <ColumnDefinition Width="110"/> <!-- 🏷️ KATEGORIE -->
                            <ColumnDefinition Width="170"/> <!-- NÁZEV -->
                            <ColumnDefinition Width="80"/>  <!-- 🚚 DODAVATEL -->
                            <ColumnDefinition Width="190"/> <!-- 📦 MATERIÁL (název od dodavatele) -->
                            <ColumnDefinition Width="70"/>  <!-- MNOŽSTVÍ -->
                            <ColumnDefinition Width="40"/>  <!-- 🔥 MJ -->
                            <ColumnDefinition Width="80"/>  <!-- 💰 CENA CELKEM -->
                            <ColumnDefinition Width="70"/>  <!-- 🔄 RESET ŘÁDKU -->
                            <ColumnDefinition Width="60"/>  <!-- 💸 SLEVA -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1" Text="Kategorie" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Název" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Dodavatel" FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Materiál" FontWeight="Bold"/>
                        <TextBlock Grid.Column="5" Text="Množství" FontWeight="Bold"
                                HorizontalAlignment="Right" TextAlignment="Right"/>
                        <TextBlock Grid.Column="6" Text="MJ" FontWeight="Bold"
                                HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="Po slevě" FontWeight="Bold"
                                HorizontalAlignment="Right" TextAlignment="Right"/>
                        <TextBlock Grid.Column="9" Text="Sleva %" FontWeight="Bold"
                                HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- ================================ -->
                    <!-- 🧱 MATERIÁL - ITEM LIST -->
                    <!-- ================================ -->
                    <ItemsControl ItemsSource="{Binding MaterialItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,5">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="35"/>  <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                                            <ColumnDefinition Width="110"/> <!-- 🏷️ KATEGORIE -->
                                            <ColumnDefinition Width="170"/> <!-- NÁZEV (produkt) -->
                                            <ColumnDefinition Width="80"/>  <!-- 🚚 DODAVATEL -->
                                            <ColumnDefinition Width="190"/> <!-- 📦 NABÍDKA -->
                                            <ColumnDefinition Width="70"/>  <!-- MNOŽSTVÍ -->
                                            <ColumnDefinition Width="40"/>  <!-- 🔥 MJ -->
                                            <ColumnDefinition Width="80"/>  <!-- 💰 CENA CELKEM -->
                                            <ColumnDefinition Width="70"/>  <!-- 🔄 RESET ŘÁDKU -->
                                            <ColumnDefinition Width="60"/>  <!-- 💸 SLEVA -->
                                        </Grid.ColumnDefinitions>

                                        <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                                        <Button Grid.Column="0"
                                                Content="−"
                                                Width="25"
                                                Height="25"
                                                Background="{DynamicResource AppDangerBrush}"
                                                Foreground="White"
                                                Command="{Binding DataContext.DeleteMaterialItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Smazat řádek"/>

                                        <!-- 🏷️ KATEGORIE (nyní VÝBĚR, ne jen zobrazení) -->
                                        <ComboBox Grid.Column="1"
                                                ItemsSource="{Binding AvailableCategories}"
                                                SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"/>

                                        <!-- NÁZEV (produktový materiál) -->
                                        <ComboBox Grid.Column="2"
                                                ItemsSource="{Binding AvailableMaterialNames}"
                                                SelectedItem="{Binding SelectedProductName, Mode=TwoWay}"
                                                IsEnabled="{Binding CanSelectProductName}"/>

                                            <!-- 🚚 DODAVATEL -->
                                        <ComboBox Grid.Column="3"
                                                ItemsSource="{Binding AvailableSuppliers}"
                                                SelectedItem="{Binding SelectedSupplier, Mode=TwoWay}"
                                                IsEnabled="{Binding CanSelectSupplier}"/>

                                        <!-- 📦 MATERIÁL (jen název od dodavatele, bez kódu a ceny) -->
                                        <ComboBox Grid.Column="4"
                                                ItemsSource="{Binding AvailableOffers}"
                                                SelectedItem="{Binding SelectedOffer, Mode=TwoWay}"
                                                IsEnabled="{Binding CanSelectOffer}"/>

                                        <!-- MNOŽSTVÍ -->
                                        <TextBox Grid.Column="5"
                                                TextAlignment="Right"
                                                Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                                        <!-- 🔥 MJ -->
                                        <TextBlock Grid.Column="6"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                TextAlignment="Center"
                                                Text="{Binding SelectedMaterialPrice.Unit}"/>
                                                
                                        <!-- 💰 CENA CELKEM -->
                                        <TextBlock Grid.Column="7"
                                                FontWeight="Bold"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Right"
                                                TextAlignment="Right"
                                                Text="{Binding Total, StringFormat={}{0:N0} Kč}"/>

                                        <!-- 🔄 RESET ŘÁDKU -->
                                        <Button Grid.Column="8"
                                                Content="SMAZAT"
                                                Background="{DynamicResource AppAccentBrush}"
                                                Foreground="White"
                                                Command="{Binding DataContext.ResetMaterialItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Vymazat data řádku"/>


                                        <!-- 💸 SLEVA -->
                                        <StackPanel Grid.Column="9"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">

                                            <CheckBox IsChecked="{Binding IsDiscountEnabled}"
                                                    VerticalAlignment="Center"/>

                                            <TextBox Width="25"
                                                    Margin="5,0,0,0"
                                                    TextAlignment="Right"
                                                    IsEnabled="{Binding IsDiscountEnabled}"
                                                    Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Text="%"
                                                    Margin="2,0,0,0"
                                                    Foreground="{DynamicResource AppMutedTextBrush}"/>
                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ========================= -->
                    <!-- 🧱 SOUČET MATERIÁLU -->
                    <!-- ========================= -->
                    <Border Margin="0,10,0,0"
                            Padding="10"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Součet materiálu"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AppSuccessBrush}"/>

                            <TextBlock Grid.Column="1"
                                    Text="{Binding MaterialTotal, StringFormat={}{0:N0} Kč}"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AppSuccessBrush}"
                                    HorizontalAlignment="Right"
                                    TextAlignment="Right"/>
                        </Grid>
                    </Border> 

                </StackPanel>

                <!-- ========================================================= -->
                <!-- 📊 SPOLEČNÝ ROZPIS (PRÁCE + MATERIÁL) -->
                <!-- ========================================================= -->
                <GroupBox Grid.Row="2">
                    <GroupBox.Header>
                        <TextBlock Text="DETAILNÍ ROZPOČET"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                    </GroupBox.Header>

                    <ListView ItemsSource="{Binding BudgetItems}">

                        <ListView.View>
                            <GridView>

                                <GridViewColumn Header="Typ"
                                                Width="100"
                                                DisplayMemberBinding="{Binding Type}"/>

                                <GridViewColumn Header="Popis"
                                                Width="350"
                                                DisplayMemberBinding="{Binding Description}"/>

                                <!-- Množství + MJ -->
                                <GridViewColumn Width="100">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Množství (MJ)"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N0}{1}">
                                                        <Binding Path="Quantity"/>
                                                        <Binding Path="Unit"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Cena před slevou -->
                                <GridViewColumn Width="120">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Před slevou"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PriceBeforeDiscount, StringFormat={}{0:N0} Kč}"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- 🏷️ Sleva % -->
                                <!-- Pokud je DiscountPercent null → zobrazí se prázdná buňka -->
                                <GridViewColumn Width="80">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Sleva %"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="60"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DiscountPercent,
                                                               TargetNullValue='',
                                                               StringFormat={}{0:N0} %}"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="60"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- 🏷️ Sleva Kč -->
                                <!-- Pokud je DiscountAmount null → zobrazí se prázdná buňka -->
                                <GridViewColumn Width="120">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Sleva Kč"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DiscountAmount,
                                                               TargetNullValue='',
                                                               StringFormat={}{0:N0} Kč}"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Foreground="{DynamicResource AppWarningBrush}"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Výsledná cena po slevě -->
                                <GridViewColumn Width="120">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Po slevě"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} Kč}"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                            </GridView>
                        </ListView.View>

                    </ListView>

                </GroupBox>

                <!-- ========================================================= -->
                <!-- 💰 CELKOVÁ CENA (GRAND TOTAL) -->
                <!-- ========================================================= -->
                <!-- Souhrn ceny před slevou, výše slevy a výsledné ceny. -->
                <Grid Grid.Row="3"
                      Margin="0,10,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ── Řádek 0: Cena před slevou ── -->
                    <!-- Zobrazí se pouze pokud existuje alespoň jedna sleva -->
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Cena před slevou:"
                               FontSize="15"
                               Foreground="{DynamicResource AppMutedTextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               FontSize="15"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"
                               Text="{Binding GrandTotalBeforeDiscount, StringFormat={}{0:N0} Kč}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── Řádek 1: Celková sleva ── -->
                    <!-- Zobrazí se pouze pokud existuje alespoň jedna sleva -->
                    <!-- ── Řádek 1: Celková sleva ── -->
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               FontSize="15"
                               Foreground="{DynamicResource AppWarningBrush}"
                               HorizontalAlignment="Left"
                               Text="Celková sleva:">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               FontSize="15"
                               Foreground="{DynamicResource AppWarningBrush}"
                               HorizontalAlignment="Right"
                               Text="{Binding TotalDiscount, StringFormat={}- {0:N0} Kč}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── Řádek 2: Oddělovač ── -->
                    <!-- Zobrazí se pouze pokud existuje alespoň jedna sleva -->
                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Margin="0,4,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- ── Řádek 3: Celková cena po slevě ── -->
                    <!-- Vždy viditelný -->
                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="Celková cena nabídky:"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AppSuccessBrush}"
                               Text="{Binding GrandTotal, StringFormat={}{0:N0} Kč}"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"/>

                </Grid>

             </Grid>
        </ScrollViewer>

    </DockPanel>
</Window>
