<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="1200"
        Width="1000">

    <!-- =========================================================== -->
    <!-- HLAVNÍ LAYOUT: Menu + Toolbar + Obsah                        -->
    <!-- DockPanel umožňuje menu a toolbar "přilepit" nahoru a        -->
    <!-- obsahu nechat zbytek prostoru (LastChildFill=True)           -->
    <!-- =========================================================== -->
    <DockPanel LastChildFill="True">

        <!-- ======================================================= -->
        <!-- 📋 MENU — klasické menu nahoře (File | ...)             -->
        <!-- ======================================================= -->
        <Menu DockPanel.Dock="Top">

            <!-- ===================== -->
            <!-- SOUBOR                -->
            <!-- ===================== -->
            <MenuItem Header="_Soubor">

                <!-- Nový projekt — resetuje celou kalkulaci -->
                <MenuItem Header="_Nový projekt"
                          InputGestureText="Ctrl+N"
                          Click="MenuNewProject_Click"/>

                <Separator/>

                <!-- Otevřít — načte projekt z .eof souboru -->
                <MenuItem Header="_Otevřít..."
                          InputGestureText="Ctrl+O"
                          Click="MenuLoad_Click"/>

                <Separator/>

                <!-- Uložit — uloží na aktuální cestu (nebo vyvolá Save As) -->
                <MenuItem Header="_Uložit"
                          InputGestureText="Ctrl+S"
                          Click="MenuSave_Click"/>

                <!-- Uložit jako — vždy otevře dialog pro výběr cesty -->
                <MenuItem Header="Uložit _jako..."
                          InputGestureText="Ctrl+Shift+S"
                          Click="MenuSaveAs_Click"/>


                <!-- Tisk nabídky-->
                <MenuItem Header="_Tisk"
                          InputGestureText="Ctrl+P"
                          Click="MenuPrint_Click"/>

                <!-- Konec — ukončí aplikaci (zeptá se na uložení) -->
                <MenuItem Header="_Konec"
                          InputGestureText="Alt+F4"
                          Click="MenuExit_Click"/>

            </MenuItem>

            <!-- ===================== -->
            <!-- NÁPOVĚDA             -->
            <!-- ===================== -->
            <MenuItem Header="_Nápověda">

                <!-- O aplikaci — zobrazí logo, verzi a autora -->
                <MenuItem Header="_O aplikaci..."
                          Click="MenuAbout_Click"/>

            </MenuItem>

        </Menu>

        <!-- ======================================================= -->
        <!-- 🔧 TOOLBAR — tlačítka pod menu pro rychlý přístup       -->
        <!-- ToolBar.Band / BandIndex řídí řazení na toolbaru        -->
        <!-- ======================================================= -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>

                <!-- Nový projekt -->
                <Button Content="🆕 Nový"
                        ToolTip="Nový projekt (Ctrl+N)"
                        Click="MenuNewProject_Click"
                        Margin="2"/>

                <Separator/>

                <!-- Otevřít -->
                <Button Content="📂 Otevřít"
                        ToolTip="Načíst projekt (Ctrl+O)"
                        Click="MenuLoad_Click"
                        Margin="2"/>

                <!-- Uložit -->
                <Button Content="💾 Uložit"
                        ToolTip="Uložit projekt (Ctrl+S)"
                        Click="MenuSave_Click"
                        Margin="2"/>

                <!-- Uložit jako -->
                <Button Content="💾 Uložit jako"
                        ToolTip="Uložit jako... (Ctrl+Shift+S)"
                        Click="MenuSaveAs_Click"
                        Margin="2"/>

                <!-- Tisk -->
                <Button Content="🖨️ Tisk"
                        ToolTip="Tisk"
                        Click="MenuPrint_Click"
                        Margin="2"/>

                <Separator/>

                <!-- ADD-KOMENT: PDF tlačítka v toolbaru — odkomentovat až bude PDF export implementován -->
                <!--
                <Separator/>

                <Button Content="📄 PDF kalkulace"
                        ToolTip="Exportovat kalkulaci do PDF"
                        Click="MenuExportPdf_Click"
                        Margin="2"/>

                <Button Content="📄 PDF ceník"
                        ToolTip="Exportovat ceník do PDF"
                        Click="MenuExportPricePdf_Click"
                        Margin="2"/>
                -->

            </ToolBar>
        </ToolBarTray>

        <!-- ======================================================= -->
        <!-- 📌 STAVOVÝ ŘÁDEK — název projektu + stav uložení        -->
        <!-- Zobrazuje aktuální název souboru a zda jsou neuložené    -->
        <!-- změny (hvězdička * v titulku je běžná konvence v IT)    -->
        <!-- ======================================================= -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="Gray"
                           FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ======================================================= -->
        <!-- 📄 HLAVNÍ OBSAH — původní Grid s kalkulací              -->
        <!-- Přesunut dovnitř DockPanelu, jinak vše stejné           -->
        <!-- ======================================================= -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ========================================================= -->
                <!-- 🔧 SEKCE: PRÁCE -->
                <!-- ========================================================= -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">

                    <!-- ========================= -->
                    <!-- HLAVIČKA SEKCE -->
                    <!-- ========================= -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="PRÁCE"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <Button Content="+"
                                Width="30"
                                Margin="10,0,0,0"
                                Click="AddWorkItem_Click"
                                ToolTip="Přidat řádek práce"/>
                    </StackPanel>

                    <!-- ========================= -->
                    <!-- HLAVIČKA TABULKY -->
                    <!-- ========================= -->
                    <Grid Margin="0,8,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>  <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                            <ColumnDefinition Width="150"/> <!-- ÚKON -->
                            <ColumnDefinition Width="150"/> <!-- UPŘESNĚNÍ -->
                            <ColumnDefinition Width="150"/> <!-- MATERIÁL -->
                            <ColumnDefinition Width="120"/> <!-- UMÍSTĚNÍ -->
                            <ColumnDefinition Width="60"/>  <!-- MNOŽSTVÍ -->
                            <ColumnDefinition Width="40"/>  <!-- 🔥 MJ -->
                            <ColumnDefinition Width="80"/>  <!-- 💰 CENA PRÁCE -->
                            <ColumnDefinition Width="70"/>  <!-- 🔄 RESET ŘÁDKU -->
                            <ColumnDefinition Width="60"/>  <!-- 💸 SLEVA -->
                        </Grid.ColumnDefinitions>

                        <!-- ÚKON -->
                        <TextBlock Grid.Column="1"
                                   Text="Úkon"
                                   FontWeight="Bold"/>

                        <!-- UPŘESNĚNÍ -->
                        <TextBlock Grid.Column="2"
                                   Text="Upřesnění"
                                   FontWeight="Bold"/>

                        <!-- MATERIÁL -->
                        <TextBlock Grid.Column="3"
                                   Text="Materiál"
                                   FontWeight="Bold"/>

                        <!-- UMÍSTĚNÍ -->
                        <TextBlock Grid.Column="4"
                                   Text="Umístění"
                                   FontWeight="Bold"/>

                        <!-- MNOŽSTVÍ -->
                        <TextBlock Grid.Column="5"
                                   Text="Množství"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"/>

                        <!-- 🔥 MJ -->
                        <TextBlock Grid.Column="6"
                                   Text="MJ"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>

                        <!-- 💰 CENA PRÁCE -->
                        <TextBlock Grid.Column="7"
                                   Text="Cena"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"/>

                        <!-- 💸 SLEVA -->
                        <TextBlock Grid.Column="9"
                                   Text="Sleva %"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                    </Grid>

                    <!-- ========================= -->
                    <!-- ITEM LIST: PRÁCE -->
                    <!-- ========================= -->
                    <ItemsControl ItemsSource="{Binding WorkCalcItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="#E0E0E0"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,5">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="35"/>  <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                                            <ColumnDefinition Width="150"/> <!-- ÚKON -->
                                            <ColumnDefinition Width="150"/> <!-- UPŘESNĚNÍ -->
                                            <ColumnDefinition Width="150"/> <!-- MATERIÁL -->
                                            <ColumnDefinition Width="120"/> <!-- UMÍSTĚNÍ -->
                                            <ColumnDefinition Width="60"/>  <!-- MNOŽSTVÍ -->
                                            <ColumnDefinition Width="40"/>  <!-- 🔥 MJ -->
                                            <ColumnDefinition Width="80"/>  <!-- 💰 CENA PRÁCE -->
                                            <ColumnDefinition Width="70"/>  <!-- 🔄 RESET ŘÁDKU -->
                                            <ColumnDefinition Width="60"/>  <!-- 💸 SLEVA -->
                                        </Grid.ColumnDefinitions>

                                        <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                                        <Button Grid.Column="0"
                                                Content="−"
                                                Width="25"
                                                Height="25"
                                                Background="#E53935"
                                                Foreground="White"
                                                Click="DeleteWorkItem_Click"
                                                ToolTip="Smazat řádek"/>

                                        <!-- ÚKON -->
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding DataContext.Tasks, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedTask, Mode=TwoWay}"/>

                                        <!-- UPŘESNĚNÍ -->
                                        <ComboBox Grid.Column="2"
                                                  IsEnabled="{Binding CanSelectSpecification}"
                                                  ItemsSource="{Binding AvailableSpecifications}"
                                                  SelectedItem="{Binding SelectedSpecification, Mode=TwoWay}"/>

                                        <!-- MATERIÁL -->
                                        <ComboBox Grid.Column="3"
                                                  IsEnabled="{Binding CanSelectMaterial}"
                                                  ItemsSource="{Binding AvailableMaterials}"
                                                  SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}"/>

                                        <!-- UMÍSTĚNÍ -->
                                        <ComboBox Grid.Column="4"
                                                  IsEnabled="{Binding CanSelectLocation}"
                                                  ItemsSource="{Binding AvailableLocations}"
                                                  SelectedItem="{Binding SelectedLocation, Mode=TwoWay}"/>

                                        <!-- MNOŽSTVÍ -->
                                        <TextBox Grid.Column="5"
                                                 TextAlignment="Right"
                                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                                        <!-- 🔥 MJ -->
                                        <TextBlock Grid.Column="6"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Foreground="Gray"
                                                   Text="{Binding WorkUnit}"/>

                                        <!-- 💰 CENA PRÁCE -->
                                        <TextBlock Grid.Column="7"
                                                   FontWeight="Bold"
                                                   Foreground="DarkBlue"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   TextAlignment="Right"
                                                   Text="{Binding Total, StringFormat={}{0:N0} Kč}"/>

                                        <!-- 🔄 RESET ŘÁDKU -->
                                        <Button Grid.Column="8"
                                                Content="SMAZAT"
                                                Background="DarkBlue"
                                                Foreground="White"
                                                Click="ResetWorkItem_Click"
                                                ToolTip="Vymazat data řádku"/>

                                        <!-- 💸 SLEVA -->
                                        <StackPanel Grid.Column="9"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">

                                            <CheckBox IsChecked="{Binding IsDiscountEnabled}"
                                                      VerticalAlignment="Center"/>

                                            <TextBox Width="25"
                                                     Margin="5,0,0,0"
                                                     TextAlignment="Right"
                                                     IsEnabled="{Binding IsDiscountEnabled}"
                                                     Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Text="%"
                                                       Margin="2,0,0,0"
                                                       Foreground="Gray"/>
                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ========================================================= -->
                    <!-- ➕ SOUČET PRÁCE -->
                    <!-- ========================================================= -->
                    <Border Margin="0,10,0,0"
                            Padding="10"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Součet práce"
                                       FontWeight="Bold"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding WorkTotal, StringFormat={}{0:N0} Kč}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="DarkBlue"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right"/>
                        </Grid>

                    </Border>

                </StackPanel>

                <!-- ========================================================= -->
                <!-- 📦 SEKCE: MATERIÁL -->
                <!-- ========================================================= -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">

                    <!-- ========================= -->
                    <!-- HLAVIČKA SEKCE -->
                    <!-- ========================= -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="MATERIÁL"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <Button Content="+"
                                Width="30"
                                Margin="10,0,0,0"
                                Click="AddMaterialsItem_Click"
                                ToolTip="Přidat řádek materiálu"/>
                    </StackPanel>

                    <!-- ========================= -->
                    <!-- HLAVIČKA TABULKY -->
                    <!-- ========================= -->
                    <Grid Margin="0,8,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>  <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                            <ColumnDefinition Width="300"/> <!-- NÁZEV -->
                            <ColumnDefinition Width="70"/>  <!-- MNOŽSTVÍ -->
                            <ColumnDefinition Width="40"/>  <!-- 🔥 MJ -->
                            <ColumnDefinition Width="80"/>  <!-- 💰 CENA MATERIÁLU -->
                            <ColumnDefinition Width="70"/>  <!-- 🔄 RESET ŘÁDKU -->
                            <ColumnDefinition Width="60"/>  <!-- 💸 SLEVA -->
                        </Grid.ColumnDefinitions>

                        <!-- NÁZEV -->
                        <TextBlock Grid.Column="1"
                                   Text="Název"
                                   FontWeight="Bold"/>

                        <!-- MNOŽSTVÍ -->
                        <TextBlock Grid.Column="2"
                                   Text="Množství"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"/>

                        <!-- 🔥 MJ -->
                        <TextBlock Grid.Column="3"
                                   Text="MJ"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>

                        <!-- 💰 CENA MATERIÁLU -->
                        <TextBlock Grid.Column="4"
                                   Text="Cena"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"/>

                        <!-- 💸 SLEVA -->
                        <TextBlock Grid.Column="6"
                                   Text="Sleva %"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>

                    </Grid>

                    <!-- ========================= -->
                    <!-- ITEM LIST: MATERIÁL -->
                    <!-- ========================= -->
                    <ItemsControl ItemsSource="{Binding MaterialItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="#E0E0E0"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,5">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="35"/>  <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                                            <ColumnDefinition Width="300"/> <!-- NÁZEV -->
                                            <ColumnDefinition Width="70"/>  <!-- MNOŽSTVÍ -->
                                            <ColumnDefinition Width="40"/>  <!-- 🔥 MJ -->
                                            <ColumnDefinition Width="80"/>  <!-- 💰 CENA MATERIÁLU -->
                                            <ColumnDefinition Width="70"/>  <!-- 🔄 RESET ŘÁDKU -->
                                            <ColumnDefinition Width="60"/>  <!-- 💸 SLEVA -->
                                        </Grid.ColumnDefinitions>

                                        <!-- ➖ SMAZÁNÍ ŘÁDKU -->
                                        <Button Grid.Column="0"
                                                Content="−"
                                                Width="25"
                                                Height="25"
                                                Background="#E53935"
                                                Foreground="White"
                                                Click="DeleteMaterialItem_Click"
                                                ToolTip="Smazat řádek"/>

                                        <!-- NÁZEV -->
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Name"
                                                  SelectedItem="{Binding MaterialItem, Mode=TwoWay}"/>

                                        <!-- MNOŽSTVÍ -->
                                        <TextBox Grid.Column="2"
                                                 TextAlignment="Right"
                                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                                        <!-- 🔥 MJ -->
                                        <TextBlock Grid.Column="3"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Text="{Binding MaterialItem.Unit}"/>

                                        <!-- 💰 CENA MATERIÁLU -->
                                        <TextBlock Grid.Column="4"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   TextAlignment="Right"
                                                   Text="{Binding Total, StringFormat={}{0:N0} Kč}"/>

                                        <!-- 🔄 RESET ŘÁDKU -->
                                        <Button Grid.Column="5"
                                                Content="SMAZAT"
                                                Background="DarkBlue"
                                                Foreground="White"
                                                Click="ResetMaterialItem_Click"
                                                ToolTip="Vymazat data řádku"/>

                                        <!-- 💸 SLEVA -->
                                        <StackPanel Grid.Column="6"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">

                                            <CheckBox IsChecked="{Binding IsDiscountEnabled}"
                                                      VerticalAlignment="Center"/>

                                            <TextBox Width="25"
                                                     Margin="5,0,0,0"
                                                     TextAlignment="Right"
                                                     IsEnabled="{Binding IsDiscountEnabled}"
                                                     Text="{Binding DiscountPercent, UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Text="%"
                                                       Margin="2,0,0,0"
                                                       Foreground="Gray"/>
                                        </StackPanel>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ========================================================= -->
                    <!-- ➕ SOUČET MATERIÁLU -->
                    <!-- ========================================================= -->
                    <Border Margin="0,10,0,0"
                            Padding="10"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Součet materiálu"
                                       FontWeight="Bold"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding MaterialTotal, StringFormat={}{0:N0} Kč}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="DarkBlue"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right"/>
                        </Grid>

                    </Border>

                </StackPanel>

                <!-- ========================================================= -->
                <!-- 📊 SPOLEČNÝ ROZPIS (PRÁCE + MATERIÁL) -->
                <!-- ========================================================= -->
                <GroupBox Grid.Row="2">
                    <GroupBox.Header>
                        <TextBlock Text="DETAILNÍ ROZPOČET"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                    </GroupBox.Header>

                    <ListView ItemsSource="{Binding BudgetItems}">

                        <ListView.View>
                            <GridView>

                                <GridViewColumn Header="Typ"
                                                Width="100"
                                                DisplayMemberBinding="{Binding Type}"/>

                                <GridViewColumn Header="Popis"
                                                Width="350"
                                                DisplayMemberBinding="{Binding Description}"/>

                                <!-- Množství + MJ -->
                                <GridViewColumn Width="100">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Množství (MJ)"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N0}{1}">
                                                        <Binding Path="Quantity"/>
                                                        <Binding Path="Unit"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Cena (se slevou) -->
                                <GridViewColumn Width="120">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Cena"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} Kč}"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- 🏷️ Sleva % -->
                                <!-- Pokud je DiscountPercent null → zobrazí se prázdná buňka -->
                                <GridViewColumn Width="80">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Sleva %"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="60"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DiscountPercent,
                                                               TargetNullValue='',
                                                               StringFormat={}{0:N0} %}"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="60"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- 🏷️ Sleva Kč -->
                                <!-- Pokud je DiscountAmount null → zobrazí se prázdná buňka -->
                                <GridViewColumn Width="120">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Sleva Kč"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DiscountAmount,
                                                               TargetNullValue='',
                                                               StringFormat={}{0:N0} Kč}"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Foreground="DarkRed"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                            </GridView>
                        </ListView.View>

                    </ListView>

                </GroupBox>

                <!-- ========================================================= -->
                <!-- 💰 CELKOVÁ CENA (GRAND TOTAL) -->
                <!-- ========================================================= -->
                <!-- 🔴 ZMĚNA: Grid rozšířen o 3 řádky — před slevou / sleva / po slevě -->
                <Grid Grid.Row="3"
                      Margin="0,10,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- ── Řádek 0: Cena před slevou ── -->
                    <!-- Zobrazí se pouze pokud existuje alespoň jedna sleva -->
                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Cena před slevou:"
                               FontSize="15"
                               Foreground="Gray">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               FontSize="15"
                               Foreground="Gray"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"
                               Text="{Binding GrandTotalBeforeDiscount, StringFormat={}{0:N0} Kč}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── Řádek 1: Celková sleva ── -->
                    <!-- Zobrazí se pouze pokud existuje alespoň jedna sleva -->
                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Celková sleva:"
                               FontSize="15"
                               Foreground="DarkRed">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               FontSize="15"
                               Foreground="DarkRed"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"
                               Text="{Binding TotalDiscount, StringFormat={}{0:N0} Kč}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── Řádek 2: Oddělovač ── -->
                    <!-- Zobrazí se pouze pokud existuje alespoň jedna sleva -->
                    <Border Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            BorderBrush="LightGray"
                            BorderThickness="0,0,0,1"
                            Margin="0,4,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasAnyDiscount}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- ── Řádek 3: Celková cena po slevě ── -->
                    <!-- Vždy viditelný -->
                    <TextBlock Grid.Row="3"
                               Grid.Column="0"
                               Text="Celková cena nabídky:"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="DarkGreen"
                               Text="{Binding GrandTotal, StringFormat={}{0:N0} Kč}"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"/>

                </Grid>

            </Grid>
        </ScrollViewer>

    </DockPanel>
</Window>
