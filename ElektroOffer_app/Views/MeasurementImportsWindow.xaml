<Window x:Class="ElektroOffer_app.Views.MeasurementImportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Terénní importy a přílohy"
        Width="980" Height="600" MinWidth="760" MinHeight="450"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Importovaná terénní měření" FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
        <DataGrid x:Name="ImportsGrid" Grid.Row="1" ItemsSource="{Binding}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Importováno" Binding="{Binding ImportedAt, StringFormat=g}" Width="130"/>
                <DataGridTextColumn Header="Projekt" Binding="{Binding ProjectName}" Width="180"/>
                <DataGridTextColumn Header="Místnost" Binding="{Binding AreaName}" Width="120"/>
                <DataGridTextColumn Header="Položka" Binding="{Binding ItemName}" Width="*"/>
                <DataGridTextColumn Header="Příloha" Binding="{Binding FileName}" Width="200"/>
                <DataGridTextColumn Header="Velikost" Binding="{Binding SizeText}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Otevřít přílohu" Click="OpenAttachment_Click" Padding="16,7" Margin="0,0,8,0"/>
            <Button Content="Otevřít zdrojový balíček" Click="OpenPackage_Click" Padding="16,7" Margin="0,0,8,0"/>
            <Button Content="Zavřít" IsCancel="True" Padding="16,7"/>
        </StackPanel>
    </Grid>
</Window>
