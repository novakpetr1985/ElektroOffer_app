<!--
    HLAVNÍ
    ======
    Kořenová definice WPF aplikace ElektroOffer.

    VEDLEJŠÍ
    ========
    - x:Class      → odpovídá třídě App v App.xaml.cs (namespace ElektroOffer_app)
    - StartupUri  → první okno po startu aplikace (Views/MainWindow.xaml)

    DETAILNÍ
    ========
    - Application.Resources slouží pro globální styly, slovníky, barvy apod.
      V této verzi je ponechán prázdný, připravený na budoucí ResourceDictionary.
-->
<Application x:Class="ElektroOffer_app.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
