<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace" Height="350" Width="500">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- NADPIS -->
        <TextBlock Text="Kalkulace ceny"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <!-- MATERIÁL -->
        <TextBlock Text="Materiál:" Grid.Row="1"/>
        <ComboBox x:Name="MaterialCombo"
                  Grid.Row="1"
                  Margin="0,20,0,10"
                  DisplayMemberPath="Name"
                  SelectionChanged="OnSelectionChanged"/>

        <!-- PRÁCE -->
        <TextBlock Text="Práce:" Grid.Row="2"/>
        <ComboBox x:Name="PriceItemCombo"
                  Grid.Row="2"
                  Margin="0,20,0,10"
                  DisplayMemberPath="Task"
                  SelectionChanged="OnSelectionChanged"/>

        <!-- VÝSLEDEK -->
        <TextBlock Text="Výsledek:" Grid.Row="3"
                   Margin="0,10,0,0"/>

        <TextBlock x:Name="ResultText"
                   Grid.Row="4"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="DarkGreen"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>