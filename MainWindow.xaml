<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="650"
        Width="900">

    <Window.Resources>

        <!-- JEDEN ŘÁDEK KALKULACE -->
        <DataTemplate x:Key="CalculationItemTemplate">

            <StackPanel Orientation="Horizontal" Margin="0,5">

                <!-- výběr položky -->
                <ComboBox Width="300"
                         ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                         DisplayMemberPath="Name"
                         SelectedItem="{Binding Item}"/>

                <!-- množství -->
                <TextBox Width="70"
                         Margin="10,0,0,0"
                         Text="{Binding Quantity}"/>

                <!-- jednotka (pokud máš v modelu) -->
                <TextBlock Width="40"
                        Margin="10,0,0,0"
                        Text="{Binding Item.Unit, TargetNullValue=''}"/>

                <!-- cena -->
                <TextBlock Width="120"
                           Margin="10,0,0,0"
                           FontWeight="Bold"
                           Text="{Binding Total}"/>

            </StackPanel>

        </DataTemplate>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- total -->
            <RowDefinition Height="Auto"/>
            <!-- práce -->
            <RowDefinition Height="Auto"/>
            <!-- materiál -->
            <RowDefinition Height="*"/>
            <!-- spacer -->
        </Grid.RowDefinitions>

        <!-- CELKOVÁ CENA -->
        <TextBlock x:Name="ResultText"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="DarkGreen"
                   Margin="0,0,0,20"/>

        <!-- PRÁCE -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PRÁCE"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddWorkItem_Click"/>
            </StackPanel>

            <ItemsControl x:Name="WorkItemsControl"
                          ItemTemplate="{StaticResource CalculationItemTemplate}"/>

        </StackPanel>

        <!-- MATERIÁL -->
        <StackPanel Grid.Row="2">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MATERIÁL"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddMaterialsItem_Click"/>
            </StackPanel>

            <ItemsControl x:Name="MaterialItemsControl"
                          ItemTemplate="{StaticResource CalculationItemTemplate}"/>

        </StackPanel>

    </Grid>
</Window>