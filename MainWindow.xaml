<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="650"
        Width="900">

    <Window.Resources>

        <!-- ===== MATERIÁL ŘÁDEK ===== -->
        <DataTemplate x:Key="MaterialItemTemplate">

            <StackPanel Orientation="Horizontal" Margin="0,5">

                <ComboBox Width="300"
                          ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding Item}"/>

                <TextBox Width="70"
                         Margin="10,0,0,0"
                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Width="40"
                           Margin="10,0,0,0"
                           Text="{Binding Item.Unit, TargetNullValue=''}"/>

                <TextBlock Width="120"
                           Margin="10,0,0,0"
                           FontWeight="Bold"
                           Text="{Binding Total}"/>

            </StackPanel>

        </DataTemplate>

        <!-- ===== PRÁCE ŘÁDEK ===== -->
        <DataTemplate x:Key="WorkItemTemplate">

            <StackPanel Orientation="Horizontal" Margin="0,5">

                <ComboBox Width="300"
                          ItemsSource="{Binding DataContext.WorkItems, RelativeSource={RelativeSource AncestorType=Window}}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding Item}"/>

                <TextBox Width="70"
                         Margin="10,0,0,0"
                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Width="40"
                           Margin="10,0,0,0"
                           Text="h"/>

                <TextBlock Width="120"
                           Margin="10,0,0,0"
                           FontWeight="Bold"
                           Text="{Binding Total}"/>

            </StackPanel>

        </DataTemplate>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CELKOVÁ CENA -->
        <TextBlock x:Name="ResultText"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="DarkGreen"
                   Margin="0,0,0,20"/>

        <!-- PRÁCE -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PRÁCE"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddWorkItem_Click"/>
            </StackPanel>

            <ItemsControl x:Name="WorkItemsControl"
                          ItemTemplate="{StaticResource WorkItemTemplate}"/>

        </StackPanel>

        <!-- MATERIÁL -->
        <StackPanel Grid.Row="2">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MATERIÁL"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddMaterialsItem_Click"/>
            </StackPanel>

            <ItemsControl x:Name="MaterialItemsControl"
                          ItemTemplate="{StaticResource MaterialItemTemplate}"/>

        </StackPanel>

    </Grid>
</Window>