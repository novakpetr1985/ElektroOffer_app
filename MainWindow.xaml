<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="1500"
        Width="1000">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================================================= -->
        <!-- 💰 CELKOVÁ CENA (GRAND TOTAL) -->
        <!-- ========================================================= -->
        <!-- ✔ Formát: tisíce + Kč -->
        <!-- ✔ Bez desetinných míst -->
        <TextBlock Grid.Row="0"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="DarkGreen"
                   Margin="0,0,0,20">
            <TextBlock.Text>
                <MultiBinding StringFormat="{}{0:N0} Kč">
                    <Binding Path="GrandTotal"/>
                </MultiBinding>
            </TextBlock.Text>
        </TextBlock>

        <!-- ========================================================= -->
        <!-- 🔧 SEKCE: PRÁCE -->
        <!-- ========================================================= -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">

            <!-- ========================= -->
            <!-- HLAVIČKA SEKCE -->
            <!-- ========================= -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PRÁCE"
                           FontSize="18"
                           FontWeight="Bold"/>
                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddWorkItem_Click"
                        ToolTip="Přidat řádek práce"/>
            </StackPanel>

            <!-- ========================= -->
            <!-- HLAVIČKA TABULKY -->
            <!-- ========================= -->
            <Grid Margin="0,8,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1" Text="Úkon"      FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="Upřesnění" FontWeight="Bold"/>
                <TextBlock Grid.Column="3" Text="Materiál"  FontWeight="Bold"/>
                <TextBlock Grid.Column="4" Text="Umístění"  FontWeight="Bold"/>
                <TextBlock Grid.Column="5" Text="Množství"  FontWeight="Bold"/>
                <TextBlock Grid.Column="6" Text="MJ"        FontWeight="Bold"/>
                <TextBlock Grid.Column="7" Text="Cena"      FontWeight="Bold"/>
            </Grid>

            <!-- ========================= -->
            <!-- ITEM LIST: PRÁCE -->
            <!-- ========================= -->
            <ItemsControl ItemsSource="{Binding WorkCalcItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border BorderBrush="#E0E0E0"
                                BorderThickness="0,0,0,1"
                                Padding="0,5">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <!-- ➖ Smazání řádku -->
                                <Button Grid.Column="0"
                                        Content="−"
                                        Width="25" Height="25"
                                        Background="#E53935"
                                        Foreground="White"
                                        ToolTip="Smazat řádek"
                                        Click="DeleteWorkItem_Click"/>

                                <!-- ÚKON -->
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding DataContext.Tasks, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding SelectedTask, Mode=TwoWay}"/>

                                <!-- UPŘESNĚNÍ -->
                                <ComboBox Grid.Column="2"
                                          IsEnabled="{Binding CanSelectSpecification}"
                                          ItemsSource="{Binding AvailableSpecifications}"
                                          SelectedItem="{Binding SelectedSpecification, Mode=TwoWay}"/>

                                <!-- MATERIÁL -->
                                <ComboBox Grid.Column="3"
                                          IsEnabled="{Binding CanSelectMaterial}"
                                          ItemsSource="{Binding AvailableMaterials}"
                                          SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}"/>

                                <!-- UMÍSTĚNÍ -->
                                <ComboBox Grid.Column="4"
                                          IsEnabled="{Binding CanSelectLocation}"
                                          ItemsSource="{Binding AvailableLocations}"
                                          SelectedItem="{Binding SelectedLocation, Mode=TwoWay}"/>

                                <!-- MNOŽSTVÍ -->
                                <TextBox Grid.Column="5"
                                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                                <!-- MJ -->
                                <TextBlock Grid.Column="6"
                                           VerticalAlignment="Center"
                                           Foreground="Gray"
                                           Text="{Binding WorkUnit}"/>

                                <!-- 💰 CENA PRÁCE -->
                                <TextBlock Grid.Column="7"
                                           FontWeight="Bold"
                                           Foreground="DarkBlue"
                                           Text="{Binding Total, StringFormat={}{0:N0} Kč}"/>

                                <!-- 🔄 RESET ŘÁDKU -->
                                <Button Grid.Column="8"
                                        Content="SMAZAT"
                                        Background="DarkBlue"
                                        Foreground="White"
                                        ToolTip="Vymazat data řádku"
                                        Click="ResetWorkItem_Click"/>

                            </Grid>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ========================================================= -->
            <!-- ➕ NOVÉ: SOUČET PRÁCE -->
            <!-- ========================================================= -->
            <Border Margin="0,10,0,0"
                    Padding="10"
                    BorderBrush="Gray"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Součet práce"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding WorkTotal, StringFormat={}{0:N0} Kč}"
                               FontSize="16"
                               Foreground="DarkBlue"/>
                </StackPanel>

            </Border>

        </StackPanel>

        <!-- ========================================================= -->
        <!-- 📦 SEKCE: MATERIÁL -->
        <!-- ========================================================= -->
        <StackPanel Grid.Row="2" Margin="0,0,0,20">

            <!-- ========================= -->
            <!-- HLAVIČKA SEKCE -->
            <!-- ========================= -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MATERIÁL"
                           FontSize="18"
                           FontWeight="Bold"/>
                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddMaterialsItem_Click"
                        ToolTip="Přidat řádek materiálu"/>
            </StackPanel>

            <!-- ========================= -->
            <!-- HLAVIČKA TABULKY -->
            <!-- ========================= -->
            <Grid Margin="0,8,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="1" Text="Název"    FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="Množství" FontWeight="Bold"/>
                <TextBlock Grid.Column="3" Text="MJ"       FontWeight="Bold"/>
                <TextBlock Grid.Column="4" Text="Cena"     FontWeight="Bold"/>
            </Grid>

            <!-- ========================= -->
            <!-- ITEM LIST: MATERIÁL -->
            <!-- ========================= -->
            <ItemsControl ItemsSource="{Binding MaterialItems}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border BorderBrush="#E0E0E0"
                                BorderThickness="0,0,0,1"
                                Padding="0,5">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>

                                <!-- ➖ Smazání řádku -->
                                <Button Grid.Column="0"
                                        Content="−"
                                        Width="25"
                                        Height="25"
                                        Background="#E53935"
                                        Foreground="White"
                                        ToolTip="Smazat řádek"
                                        Click="DeleteMaterialItem_Click"/>

                                <!-- Výběr materiálu -->
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                                          DisplayMemberPath="Name"
                                          SelectedItem="{Binding MaterialItem, Mode=TwoWay}"/>

                                <!-- Množství -->
                                <TextBox Grid.Column="2"
                                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                                <!-- MJ -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding MaterialItem.Unit}"/>

                                <!-- 💰 CENA MATERIÁLU -->
                                <TextBlock Grid.Column="4"
                                           FontWeight="Bold"
                                           Text="{Binding Total, StringFormat={}{0:N0} Kč}"/>

                                <!-- 🔄 RESET ŘÁDKU -->
                                <Button Grid.Column="5"
                                        Content="SMAZAT"
                                        Background="DarkBlue"
                                        Foreground="White"
                                        ToolTip="Vymazat data řádku"
                                        Click="ResetMaterialItem_Click"/>

                            </Grid>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ========================================================= -->
            <!-- ➕ NOVÉ: SOUČET MATERIÁLU -->
            <!-- ========================================================= -->
            <Border Margin="0,10,0,0"
                    Padding="10"
                    BorderBrush="Gray"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="Součet materiálu"
                               FontWeight="Bold"/>
                    <TextBlock Text="{Binding MaterialTotal, StringFormat={}{0:N0} Kč}"
                               FontSize="16"
                               Foreground="DarkBlue"/>
                </StackPanel>

            </Border>

        </StackPanel>

        <!-- ========================================================= -->
        <!-- 📊 SPOLEČNÝ ROZPIS (PRÁCE + MATERIÁL) -->
        <!-- ========================================================= -->
        <GroupBox Grid.Row="3"
                  Header="DETAILNÍ ROZPIS (PRÁCE + MATERIÁL)">

            <ListView ItemsSource="{Binding BudgetItems}">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="Typ"
                                        Width="100"
                                        DisplayMemberBinding="{Binding Type}"/>

                        <GridViewColumn Header="Popis"
                                        Width="400"
                                        DisplayMemberBinding="{Binding Description}"/>

                        <GridViewColumn Header="Cena"
                                        Width="120"
                                        DisplayMemberBinding="{Binding Price, StringFormat={}{0:N0} Kč}"/>

                    </GridView>

                </ListView.View>

            </ListView>

        </GroupBox>

    </Grid>
</Window>