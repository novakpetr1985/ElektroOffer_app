<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="650"
        Width="900">

    <!-- ========================= -->
    <!-- HLAVNÍ ROZLOŽENÍ -->
    <!-- ========================= -->
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- CELKOVÁ CENA -->

            <RowDefinition Height="Auto"/>
            <!-- PRÁCE -->

            <RowDefinition Height="Auto"/>
            <!-- MATERIÁL -->

            <RowDefinition Height="*"/>
            <!-- VOLNÝ PROSTOR -->
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- 💰 CELKOVÁ CENA -->
        <!-- ========================= -->
        <TextBlock Grid.Row="0"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="DarkGreen"
                   Margin="0,0,0,20"
                   Text="{Binding GrandTotal, StringFormat=N2}" />

        <!-- ========================= -->
        <!-- 🔧 PRÁCE (ROZŠÍŘENO O KOEFICIENTY) -->
        <!-- ========================= -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">

            <!-- HLAVIČKA -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PRÁCE"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddWorkItem_Click"/>
            </StackPanel>

            <!-- ========================= -->
            <!-- LIST PRÁCE -->
            <!-- ========================= -->
            <ItemsControl ItemsSource="{Binding WorkCalcItems}">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <!-- ========================= -->
                        <!-- JEDEN ŘÁDEK PRÁCE -->
                        <!-- ========================= -->
                        <StackPanel Orientation="Horizontal" Margin="0,5">

                            <!-- ========================= -->
                            <!-- 1) TASK (ÚKON) -->
                            <!-- ========================= -->
                            <ComboBox Width="150"
                                      ItemsSource="{Binding DataContext.Tasks, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedTask, Mode=TwoWay}" />

                            <!-- ========================= -->
                            <!-- 2) SPECIFICATION -->
                            <!-- ========================= -->
                            <ComboBox Width="150"
                                      Margin="5,0,0,0"
                                      ItemsSource="{Binding DataContext.Specifications, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedSpecification, Mode=TwoWay}" />

                            <!-- ========================= -->
                            <!-- 3) MATERIAL (v rámci práce) -->
                            <!-- ========================= -->
                            <ComboBox Width="150"
                                      Margin="5,0,0,0"
                                      ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}" />

                            <!-- ========================= -->
                            <!-- 4) LOCATION -->
                            <!-- ========================= -->
                            <ComboBox Width="120"
                                      Margin="5,0,0,0"
                                      ItemsSource="{Binding DataContext.Locations, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedLocation, Mode=TwoWay}" />

                            <!-- ========================= -->
                            <!-- 5) MNOŽSTVÍ -->
                            <!-- ========================= -->
                            <TextBox Width="60"
                                     Margin="10,0,0,0"
                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />

                            <!-- ========================= -->
                            <!-- 6) JEDNOTKA (z Task nebo Material) -->
                            <!-- ========================= -->
                            <TextBlock Width="50"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding SelectedMaterial.Unit}" />

                            <!-- ========================= -->
                            <!-- 7) CENA (KOEFICIENTOVÝ VÝPOČET) -->
                            <!-- MaterialCoef * PositionCoef -->
                            <!-- ========================= -->
                            <TextBlock Width="120"
                                       Margin="10,0,0,0"
                                       FontWeight="Bold"
                                       Foreground="DarkBlue"
                                       Text="{Binding Total}" />

                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

        <!-- ========================= -->
        <!-- 📦 MATERIÁL (BEZ ZMĚN LOGIKY) -->
        <!-- ========================= -->
        <StackPanel Grid.Row="2">

            <!-- HLAVIČKA -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MATERIÁL"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddMaterialsItem_Click"/>
            </StackPanel>

            <!-- LIST MATERIÁLU -->
            <ItemsControl ItemsSource="{Binding MaterialItems}">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <StackPanel Orientation="Horizontal" Margin="0,5">

                            <ComboBox Width="300"
                                      ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding MaterialItem, Mode=TwoWay}" />

                            <TextBox Width="70"
                                     Margin="10,0,0,0"
                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Width="40"
                                       Margin="10,0,0,0"
                                       Text="{Binding MaterialItem.Unit}" />

                            <TextBlock Width="120"
                                       Margin="10,0,0,0"
                                       FontWeight="Bold"
                                       Text="{Binding Total}" />

                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

    </Grid>
</Window>