<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="650"
        Width="900">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- 💰 CELKOVÁ CENA -->
        <!-- ========================= -->
        <TextBlock Grid.Row="0"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="DarkGreen"
                   Margin="0,0,0,20"
                   Text="{Binding GrandTotal, StringFormat=N2}" />

        <!-- ========================= -->
        <!-- 🔧 PRÁCE -->
        <!-- ========================= -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PRÁCE"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddWorkItem_Click"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding WorkCalcItems}">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <StackPanel Orientation="Horizontal" Margin="0,5">

                            <!-- TASK (vždy globální seznam) -->
                            <ComboBox Width="150"
                                      ItemsSource="{Binding DataContext.Tasks, RelativeSource={RelativeSource AncestorType=Window}}"
                                      SelectedItem="{Binding SelectedTask, Mode=TwoWay}" />

                            <!-- SPECIFICATION (FILTROVANÉ Z DB) -->
                            <ComboBox Width="150"
                                      Margin="5,0,0,0"
                                      IsEnabled="{Binding CanSelectSpecification}"
                                      ItemsSource="{Binding AvailableSpecifications}"
                                      SelectedItem="{Binding SelectedSpecification, Mode=TwoWay}" />

                            <!-- MATERIAL (FILTROVANÉ Z DB) -->
                            <ComboBox Width="150"
                                      Margin="5,0,0,0"
                                      IsEnabled="{Binding CanSelectMaterial}"
                                      ItemsSource="{Binding AvailableMaterials}"
                                      SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}" />

                            <!-- LOCATION (FILTROVANÉ Z DB) -->
                            <ComboBox Width="120"
                                      Margin="5,0,0,0"
                                      IsEnabled="{Binding CanSelectLocation}"
                                      ItemsSource="{Binding AvailableLocations}"
                                      SelectedItem="{Binding SelectedLocation, Mode=TwoWay}" />

                            <!-- MNOŽSTVÍ -->
                            <TextBox Width="60"
                                     Margin="10,0,0,0"
                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />

                            <!-- UNIT -->
                            <TextBlock Width="60"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="Gray"
                                       Text="{Binding WorkUnit}" />

                            <!-- CENA -->
                            <TextBlock Width="120"
                                       Margin="10,0,0,0"
                                       FontWeight="Bold"
                                       Foreground="DarkBlue"
                                       Text="{Binding Total}" />

                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

        <!-- ========================= -->
        <!-- 📦 MATERIÁL -->
        <!-- ========================= -->
        <StackPanel Grid.Row="2">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MATERIÁL"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddMaterialsItem_Click"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding MaterialItems}">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <StackPanel Orientation="Horizontal" Margin="0,5">

                            <ComboBox Width="300"
                                      ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding MaterialItem, Mode=TwoWay}" />

                            <TextBox Width="70"
                                     Margin="10,0,0,0"
                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Width="40"
                                       Margin="10,0,0,0"
                                       Text="{Binding MaterialItem.Unit}" />

                            <TextBlock Width="120"
                                       Margin="10,0,0,0"
                                       FontWeight="Bold"
                                       Text="{Binding Total}" />

                        </StackPanel>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

    </Grid>
</Window>