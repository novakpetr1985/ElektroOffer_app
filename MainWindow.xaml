<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="800"
        Width="1000">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- 💰 CELKOVÁ CENA -->
        <!-- ========================= -->
        <TextBlock Grid.Row="0"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="DarkGreen"
                   Margin="0,0,0,20"
                   Text="{Binding GrandTotal, StringFormat=N2}" />

        <!-- ========================= -->
        <!-- 🔧 PRÁCE -->
        <!-- ========================= -->
        <StackPanel Grid.Row="1" Margin="0,0,0,20">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="PRÁCE"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddWorkItem_Click"
                        ToolTip="Přidat řádek práce"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding WorkCalcItems}">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border BorderBrush="#E0E0E0"
                                BorderThickness="0,0,0,1"
                                Padding="0,5">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>

                                <!-- ========================= -->
                                <!-- ➖ DELETE ROW -->
                                <!-- ========================= -->
                                <Button Grid.Column="0"
                                        Content="−"
                                        Width="25"
                                        Height="25"
                                        Background="#E53935"
                                        Foreground="White"
                                        ToolTip="Smazat řádek"
                                        Click="DeleteWorkItem_Click"/>

                                <!-- ========================= -->
                                <!-- 🔧 DATA -->
                                <!-- ========================= -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">

                                    <ComboBox Width="150"
                                              ItemsSource="{Binding DataContext.Tasks, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding SelectedTask, Mode=TwoWay}" />

                                    <ComboBox Width="150"
                                              Margin="5,0,0,0"
                                              IsEnabled="{Binding CanSelectSpecification}"
                                              ItemsSource="{Binding AvailableSpecifications}"
                                              SelectedItem="{Binding SelectedSpecification, Mode=TwoWay}" />

                                    <ComboBox Width="150"
                                              Margin="5,0,0,0"
                                              IsEnabled="{Binding CanSelectMaterial}"
                                              ItemsSource="{Binding AvailableMaterials}"
                                              SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}" />

                                    <ComboBox Width="120"
                                              Margin="5,0,0,0"
                                              IsEnabled="{Binding CanSelectLocation}"
                                              ItemsSource="{Binding AvailableLocations}"
                                              SelectedItem="{Binding SelectedLocation, Mode=TwoWay}" />

                                    <TextBox Width="60"
                                             Margin="10,0,0,0"
                                             Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Width="60"
                                               Margin="10,0,0,0"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               Foreground="Gray"
                                               Text="{Binding WorkUnit}" />

                                    <TextBlock Width="120"
                                               Margin="10,0,0,0"
                                               FontWeight="Bold"
                                               Foreground="DarkBlue"
                                               Text="{Binding Total}" />
                                </StackPanel>

                                <!-- ========================= -->
                                <!-- 🧹 RESET -->
                                <!-- ========================= -->
                                <Button Grid.Column="2"
                                        Content="Smazat"
                                        Background="#1E88E5"
                                        Foreground="White"
                                        Padding="6,2"
                                        ToolTip="Vymazat hodnoty řádku"
                                        Click="ResetWorkItem_Click"/>
                            </Grid>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

        <!-- ========================= -->
        <!-- 📦 MATERIÁL -->
        <!-- ========================= -->
        <StackPanel Grid.Row="2">

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MATERIÁL"
                           FontSize="18"
                           FontWeight="Bold"/>

                <Button Content="+"
                        Width="30"
                        Margin="10,0,0,0"
                        Click="AddMaterialsItem_Click"
                        ToolTip="Přidat řádek materiálu"/>
            </StackPanel>

            <ItemsControl ItemsSource="{Binding MaterialItems}">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>

                        <Border BorderBrush="#E0E0E0"
                                BorderThickness="0,0,0,1"
                                Padding="0,5">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>

                                <!-- ➖ DELETE -->
                                <Button Grid.Column="0"
                                        Content="−"
                                        Width="25"
                                        Height="25"
                                        Background="#E53935"
                                        Foreground="White"
                                        ToolTip="Smazat řádek"
                                        Click="DeleteMaterialItem_Click"/>

                                <!-- DATA -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal">

                                    <ComboBox Width="300"
                                              ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="Name"
                                              SelectedItem="{Binding MaterialItem, Mode=TwoWay}" />

                                    <TextBox Width="70"
                                             Margin="10,0,0,0"
                                             Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Width="40"
                                               Margin="10,0,0,0"
                                               Text="{Binding MaterialItem.Unit}" />

                                    <TextBlock Width="120"
                                               Margin="10,0,0,0"
                                               FontWeight="Bold"
                                               Text="{Binding Total}" />

                                </StackPanel>

                                <!-- 🧹 RESET -->
                                <Button Grid.Column="2"
                                        Content="Smazat"
                                        Background="#1E88E5"
                                        Foreground="White"
                                        Padding="6,2"
                                        ToolTip="Vymazat hodnoty řádku"
                                        Click="ResetMaterialItem_Click"/>
                            </Grid>

                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>

    </Grid>
</Window>