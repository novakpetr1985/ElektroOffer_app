            if (savedPath != null)
                OnProjectSaved(savedPath);
        }

        // =========================================================
        // 📥 IMPORT / 📤 EXPORT JSON
        // =========================================================

        /// <summary>
        /// Menu: Soubor → Importovat JSON
        /// Načte ceník (PriceItems + Materials) z .eofcat souboru a uloží do DB.
        /// POZOR: Stávající záznamy v DB jsou před importem smazány (čistý import).
        /// </summary>
        private void MenuImportJson_Click(object sender, RoutedEventArgs e)
        {
            // Upozornění před importem — přepíše data v DB
            var confirm = MessageBox.Show(
                "Import přepíše stávající data ceníku v databázi.\n\n" +
                "• Položky práce (PriceItems)\n" +
                "• Položky materiálu (Materials)\n\n" +
                "Chcete pokračovat?",
                "Import ceníku — upozornění",
                MessageBoxButton.YesNo,
                MessageBoxImage.Warning);

            if (confirm != MessageBoxResult.Yes) return;

            // Načtení dat ze souboru přes ProjectService
            var importData = _projectService.ImportCatalog();
            if (importData == null) return; // uživatel zrušil nebo chyba

            try
            {
                using var db = new Data.AppDbContext();

                // =========================
                // 🗑️ SMAZÁNÍ STÁVAJÍCÍCH DAT
                // =========================
                // RemoveRange smaže všechny záznamy z tabulky před importem
                db.PriceItems.RemoveRange(db.PriceItems);
                db.Materials.RemoveRange(db.Materials);

                // =========================
                // 📥 IMPORT PRICE ITEMS
                // =========================
                foreach (var item in importData.PriceItems)
                {
                    db.PriceItems.Add(new Models.PriceItems
                    {
                        Task = item.Task,
                        Specification = item.Specification,
                        Material = item.Material,
                        Location = item.Location,
                        BasePrice = item.BasePrice,
                        Unit = item.Unit,
                        MaterialCoef = item.MaterialCoef,
                        PositionCoef = item.PositionCoef
                    });
                }

                // =========================
                // 📥 IMPORT MATERIALS
                // =========================
                foreach (var mat in importData.Materials)
                {
                    db.Materials.Add(new Models.Material
                    {
                        Name = mat.Name,
                        Unit = mat.Unit,
                        Price = mat.Price
                    });
                }

                // Uložení všech změn do DB najednou
                db.SaveChanges();

                // =========================
                // 🔄 OBNOVENÍ UI Z NOVÉ DB
                // =========================
                // Po importu znovu načteme data z DB do ObservableCollections
                Tasks.Clear();
                foreach (var task in db.PriceItems.Select(x => x.Task).Distinct().ToList())
                    Tasks.Add(task);

                Materials.Clear();
                foreach (var mat in db.Materials.ToList())
                    Materials.Add(mat);

                MessageBox.Show(
                    $"Import byl úspěšně dokončen.\n\n" +
                    $"Importováno položek práce: {importData.PriceItems.Count}\n" +
                    $"Importováno položek materiálu: {importData.Materials.Count}",
                    "Import dokončen",
                    MessageBoxButton.OK,
                    MessageBoxImage.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Chyba při ukládání importovaných dat do databáze:\n{ex.Message}",
                    "Chyba importu", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        /// <summary>
        /// Menu: Soubor → Exportovat JSON
        /// Uloží aktuální ceník z DB (PriceItems + Materials) do .eofcat souboru.
        /// </summary>
        private void MenuExportJson_Click(object sender, RoutedEventArgs e)
        {
            try
            {
                // Načtení dat z DB
                using var db = new Data.AppDbContext();

                // =========================
                // 📦 SESTAVENÍ EXPORT DAT
                // =========================
                var exportData = new Models.CatalogExportData
                {
                    // Převod PriceItems z DB do exportního formátu
                    PriceItems = db.PriceItems.Select(x => new Models.PriceItemExportData
                    {
                        Task = x.Task,
                        Specification = x.Specification,
                        Material = x.Material,
                        Location = x.Location,
                        BasePrice = x.BasePrice,
                        Unit = x.Unit,
                        MaterialCoef = x.MaterialCoef,
                        PositionCoef = x.PositionCoef
                    }).ToList(),

                    // Převod Materials z DB do exportního formátu
                    Materials = db.Materials.Select(m => new Models.MaterialExportData
                    {
                        Name = m.Name,
                        Unit = m.Unit,
                        Price = m.Price
                    }).ToList()
                };

                // Předání dat do ProjectService který otevře dialog a uloží soubor
                _projectService.ExportCatalog(exportData);
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Chyba při načítání dat z databáze:\n{ex.Message}",
                    "Chyba exportu", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

