                            <!-- 🔴 ZMĚNA: chybějící HorizontalAlignment="Right" doplněn -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding MaterialTotal, StringFormat={}{0:N0} Kč}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="DarkBlue"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right"/>
                        </Grid>

                    </Border>

                </StackPanel>

                <!-- ========================================================= -->
                <!-- 📊 SPOLEČNÝ ROZPIS (PRÁCE + MATERIÁL) -->
                <!-- ========================================================= -->
                <GroupBox Grid.Row="2">
                    <GroupBox.Header>
                        <TextBlock Text="DETAILNÍ ROZPOČET"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                    </GroupBox.Header>

                    <ListView ItemsSource="{Binding BudgetItems}">

                        <ListView.View>
                            <GridView>

                                <GridViewColumn Header="Typ"
                                                Width="100"
                                                DisplayMemberBinding="{Binding Type}"/>

                                <GridViewColumn Header="Popis"
                                                Width="350"
                                                DisplayMemberBinding="{Binding Description}"/>

                                <!-- ✔ NOVĚ: Množství + MJ -->
                                <GridViewColumn Width="100">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Množství (MJ)"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- ✔ OPRAVA: zobrazí "Xm" místo pouhého "m" -->
                                            <TextBlock HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0:N0}{1}">
                                                        <Binding Path="Quantity"/>
                                                        <Binding Path="Unit"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                                <!-- Cena -->
                                <GridViewColumn Width="120">
                                    <GridViewColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="Cena"
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.HeaderTemplate>

                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} Kč}"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Width="100"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>

                            </GridView>
                        </ListView.View>

                    </ListView>

                </GroupBox>

                <!-- ========================================================= -->
                <!-- 💰 CELKOVÁ CENA (GRAND TOTAL) -->
                <!-- ========================================================= -->
                <!-- 🔴 ZMĚNA: StackPanel -> Grid kvůli zarovnání -->
                <Grid Grid.Row="3"
                      Margin="0,10,0,20">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Celková cena nabídky:"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Grid.Column="1"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="DarkGreen"
                               Text="{Binding GrandTotal, StringFormat={}{0:N0} Kč}"
                               HorizontalAlignment="Right"
                               TextAlignment="Right"/>

                </Grid>

            </Grid>
        </ScrollViewer>

    </DockPanel>
</Window>



