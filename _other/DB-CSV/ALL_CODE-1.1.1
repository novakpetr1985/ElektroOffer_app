<Window x:Class="ElektroOffer_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elektro Offer - Kalkulace"
        Height="1000"
        Width="1000">

    <!-- =========================================================== -->
    <!-- HLAVNÍ LAYOUT: Menu + Toolbar + Obsah                        -->
    <!-- DockPanel umožňuje menu a toolbar "přilepit" nahoru a        -->
    <!-- obsahu nechat zbytek prostoru (LastChildFill=True)           -->
    <!-- =========================================================== -->
    <DockPanel LastChildFill="True">

        <!-- ======================================================= -->
        <!-- 📋 MENU — klasické menu nahoře (File | ...)             -->
        <!-- ======================================================= -->
        <Menu DockPanel.Dock="Top">

            <!-- ===================== -->
            <!-- SOUBOR                -->
            <!-- ===================== -->
            <MenuItem Header="_Soubor">

                <!-- Nový projekt — resetuje celou kalkulaci -->
                <MenuItem Header="_Nový projekt"
                          InputGestureText="Ctrl+N"
                          Click="MenuNewProject_Click"/>

                <Separator/>

                <!-- Otevřít — načte projekt z .eof souboru -->
                <MenuItem Header="_Otevřít..."
                          InputGestureText="Ctrl+O"
                          Click="MenuLoad_Click"/>

                <Separator/>

                <!-- Uložit — uloží na aktuální cestu (nebo vyvolá Save As) -->
                <MenuItem Header="_Uložit"
                          InputGestureText="Ctrl+S"
                          Click="MenuSave_Click"/>

                <!-- Uložit jako — vždy otevře dialog pro výběr cesty -->
                <MenuItem Header="Uložit _jako..."
                          InputGestureText="Ctrl+Shift+S"
                          Click="MenuSaveAs_Click"/>

                <Separator/>

                <!-- Import JSON — načte ceník/data z externího JSON souboru -->
                <MenuItem Header="_Importovat JSON..."
                          Click="MenuImportJson_Click"/>

                <!-- Export JSON — uloží ceník/data do externího JSON souboru -->
                <MenuItem Header="_Exportovat JSON..."
                          Click="MenuExportJson_Click"/>

                <Separator/>

                <!-- ADD-KOMENT: PDF export — implementovat až bude finální struktura dokumentu (sekce zákazníka) -->
                <!-- ADD-KOMENT: Plánovaná knihovna: QuestPDF — nainstalovat přes NuGet: Install-Package QuestPDF -->
                <!--
                <MenuItem Header="Export _PDF (kalkulace)"
                          Click="MenuExportPdf_Click"/>

                <MenuItem Header="Export PDF (_ceník)"
                          Click="MenuExportPricePdf_Click"/>
                -->

                <Separator/>

                <!-- Konec — ukončí aplikaci (zeptá se na uložení) -->
                <MenuItem Header="_Konec"
                          InputGestureText="Alt+F4"
                          Click="MenuExit_Click"/>

            </MenuItem>

            <!-- ===================== -->
            <!-- NÁPOVĚDA             -->
            <!-- ===================== -->
            <MenuItem Header="_Nápověda">

                <!-- O aplikaci — zobrazí logo, verzi a autora -->
                <MenuItem Header="_O aplikaci..."
                          Click="MenuAbout_Click"/>

            </MenuItem>

        </Menu>

        <!-- ======================================================= -->
        <!-- 🔧 TOOLBAR — tlačítka pod menu pro rychlý přístup       -->
        <!-- ToolBar.Band / BandIndex řídí řazení na toolbaru        -->
        <!-- ======================================================= -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>

                <!-- Nový projekt -->
                <Button Content="🆕 Nový"
                        ToolTip="Nový projekt (Ctrl+N)"
                        Click="MenuNewProject_Click"
                        Margin="2"/>

                <Separator/>

                <!-- Otevřít -->
                <Button Content="📂 Otevřít"
                        ToolTip="Načíst projekt (Ctrl+O)"
                        Click="MenuLoad_Click"
                        Margin="2"/>

                <!-- Uložit -->
                <Button Content="💾 Uložit"
                        ToolTip="Uložit projekt (Ctrl+S)"
                        Click="MenuSave_Click"
                        Margin="2"/>

                <!-- Uložit jako -->
                <Button Content="💾 Uložit jako"
                        ToolTip="Uložit jako... (Ctrl+Shift+S)"
                        Click="MenuSaveAs_Click"
                        Margin="2"/>

                <Separator/>

                <!-- Import JSON — načtení dat z externího JSON souboru -->
                <Button Content="📥 Import JSON"
                        ToolTip="Importovat data z JSON souboru"
                        Click="MenuImportJson_Click"
                        Margin="2"/>

                <!-- Export JSON — uložení dat do externího JSON souboru -->
                <Button Content="📤 Export JSON"
                        ToolTip="Exportovat data do JSON souboru"
                        Click="MenuExportJson_Click"
                        Margin="2"/>

                <!-- ADD-KOMENT: PDF tlačítka v toolbaru — odkomentovat až bude PDF export implementován -->
                <!--
                <Separator/>

                <Button Content="📄 PDF kalkulace"
                        ToolTip="Exportovat kalkulaci do PDF"
                        Click="MenuExportPdf_Click"
                        Margin="2"/>

                <Button Content="📄 PDF ceník"
                        ToolTip="Exportovat ceník do PDF"
                        Click="MenuExportPricePdf_Click"
                        Margin="2"/>
                -->

            </ToolBar>
        </ToolBarTray>

        <!-- ======================================================= -->
        <!-- 📌 STAVOVÝ ŘÁDEK — název projektu + stav uložení        -->
        <!-- Zobrazuje aktuální název souboru a zda jsou neuložené    -->
        <!-- změny (hvězdička * v titulku je běžná konvence v IT)    -->
        <!-- ======================================================= -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="Gray"
                           FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ======================================================= -->
        <!-- 📄 HLAVNÍ OBSAH — původní Grid s kalkulací              -->
        <!-- Přesunut dovnitř DockPanelu, jinak vše stejné           -->
        <!-- ======================================================= -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ========================================================= -->
                <!-- 🔧 SEKCE: PRÁCE -->
                <!-- ========================================================= -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">

                    <!-- ========================= -->
                    <!-- HLAVIČKA SEKCE -->
                    <!-- ========================= -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="PRÁCE"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <Button Content="+"
                                Width="30"
                                Margin="10,0,0,0"
                                Click="AddWorkItem_Click"
                                ToolTip="Přidat řádek práce"/>
                    </StackPanel>

                    <!-- ========================= -->
                    <!-- HLAVIČKA TABULKY -->
                    <!-- ========================= -->
                    <Grid Margin="0,8,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1" Text="Úkon"      FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="Upřesnění" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="Materiál"  FontWeight="Bold"/>
                        <TextBlock Grid.Column="4" Text="Umístění"  FontWeight="Bold"/>

                        <!-- 🔴 ZMĚNA: číselné sloupce zarovnány shodně s obsahem -->
                        <TextBlock Grid.Column="5" Text="Množství"  FontWeight="Bold"
                                   HorizontalAlignment="Right" TextAlignment="Right"/>
                        <TextBlock Grid.Column="6" Text="MJ"        FontWeight="Bold"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="Cena"      FontWeight="Bold"
                                   HorizontalAlignment="Right" TextAlignment="Right"/>

                    </Grid>

                    <!-- ========================= -->
                    <!-- ITEM LIST: PRÁCE -->
                    <!-- ========================= -->
                    <ItemsControl ItemsSource="{Binding WorkCalcItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="#E0E0E0"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,5">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="35"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- ➖ Smazání řádku -->
                                        <Button Grid.Column="0"
                                                Content="−"
                                                Width="25"
                                                Height="25"
                                                Background="#E53935"
                                                Foreground="White"
                                                ToolTip="Smazat řádek"
                                                Click="DeleteWorkItem_Click"/>

                                        <!-- ÚKON -->
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding DataContext.Tasks, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedTask, Mode=TwoWay}"/>

                                        <!-- UPŘESNĚNÍ -->
                                        <ComboBox Grid.Column="2"
                                                  IsEnabled="{Binding CanSelectSpecification}"
                                                  ItemsSource="{Binding AvailableSpecifications}"
                                                  SelectedItem="{Binding SelectedSpecification, Mode=TwoWay}"/>

                                        <!-- MATERIÁL -->
                                        <ComboBox Grid.Column="3"
                                                  IsEnabled="{Binding CanSelectMaterial}"
                                                  ItemsSource="{Binding AvailableMaterials}"
                                                  SelectedItem="{Binding SelectedMaterial, Mode=TwoWay}"/>

                                        <!-- UMÍSTĚNÍ -->
                                        <ComboBox Grid.Column="4"
                                                  IsEnabled="{Binding CanSelectLocation}"
                                                  ItemsSource="{Binding AvailableLocations}"
                                                  SelectedItem="{Binding SelectedLocation, Mode=TwoWay}"/>

                                        <!-- MNOŽSTVÍ -->
                                        <!-- 🔴 ZMĚNA: číslo zarovnáno doprava -->
                                        <TextBox Grid.Column="5"
                                                 TextAlignment="Right"
                                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                                        <!-- MJ -->
                                        <!-- 🔴 ZMĚNA: jednotka vycentrována -->
                                        <TextBlock Grid.Column="6"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Foreground="Gray"
                                                   Text="{Binding WorkUnit}"/>

                                        <!-- 💰 CENA PRÁCE -->
                                        <!-- 🔴 ZMĚNA: zarovnání doprava -->
                                        <TextBlock Grid.Column="7"
                                                   FontWeight="Bold"
                                                   Foreground="DarkBlue"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   TextAlignment="Right"
                                                   Text="{Binding Total, StringFormat={}{0:N0} Kč}"/>

                                        <!-- 🔄 RESET ŘÁDKU -->
                                        <Button Grid.Column="8"
                                                Content="SMAZAT"
                                                Background="DarkBlue"
                                                Foreground="White"
                                                ToolTip="Vymazat data řádku"
                                                Click="ResetWorkItem_Click"/>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ========================================================= -->
                    <!-- ➕ SOUČET PRÁCE -->
                    <!-- ========================================================= -->
                    <!-- 🔴 ZMĚNA: StackPanel -> Grid kvůli zarovnání -->
                    <Border Margin="0,10,0,0"
                            Padding="10"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Součet práce"
                                       FontWeight="Bold"/>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding WorkTotal, StringFormat={}{0:N0} Kč}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="DarkBlue"
                                       HorizontalAlignment="Right"
                                       TextAlignment="Right"/>
                        </Grid>

                    </Border>

                </StackPanel>

                <!-- ========================================================= -->
                <!-- 📦 SEKCE: MATERIÁL -->
                <!-- ========================================================= -->
                <StackPanel Grid.Row="1" Margin="0,0,0,20">

                    <!-- ========================= -->
                    <!-- HLAVIČKA SEKCE -->
                    <!-- ========================= -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="MATERIÁL"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <Button Content="+"
                                Width="30"
                                Margin="10,0,0,0"
                                Click="AddMaterialsItem_Click"
                                ToolTip="Přidat řádek materiálu"/>
                    </StackPanel>

                    <!-- ========================= -->
                    <!-- HLAVIČKA TABULKY -->
                    <!-- ========================= -->
                    <Grid Margin="0,8,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="35"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1" Text="Název"    FontWeight="Bold"/>

                        <!-- 🔴 ZMĚNA: číselné sloupce zarovnány shodně s obsahem -->
                        <TextBlock Grid.Column="2" Text="Množství" FontWeight="Bold"
                                   HorizontalAlignment="Right" TextAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="MJ"       FontWeight="Bold"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="Cena"     FontWeight="Bold"
                                   HorizontalAlignment="Right" TextAlignment="Right"/>

                    </Grid>

                    <!-- ========================= -->
                    <!-- ITEM LIST: MATERIÁL -->
                    <!-- ========================= -->
                    <ItemsControl ItemsSource="{Binding MaterialItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>

                                <Border BorderBrush="#E0E0E0"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,5">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="35"/>
                                            <ColumnDefinition Width="300"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Content="−"
                                                Width="25"
                                                Height="25"
                                                Background="#E53935"
                                                Foreground="White"
                                                ToolTip="Smazat řádek"
                                                Click="DeleteMaterialItem_Click"/>

                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding DataContext.Materials, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Name"
                                                  SelectedItem="{Binding MaterialItem, Mode=TwoWay}"/>

                                        <!-- 🔴 ZMĚNA: číslo zarovnáno doprava -->
                                        <TextBox Grid.Column="2"
                                                 TextAlignment="Right"
                                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>

                                        <!-- 🔴 ZMĚNA: jednotka vycentrována -->
                                        <TextBlock Grid.Column="3"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   Text="{Binding MaterialItem.Unit}"/>

                                        <!-- 🔴 ZMĚNA: cena doprava -->
                                        <TextBlock Grid.Column="4"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   TextAlignment="Right"
                                                   Text="{Binding Total, StringFormat={}{0:N0} Kč}"/>

                                        <Button Grid.Column="5"
                                                Content="SMAZAT"
                                                Background="DarkBlue"
                                                Foreground="White"
                                                ToolTip="Vymazat data řádku"
                                                Click="ResetMaterialItem_Click"/>

                                    </Grid>

                                </Border>

                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ========================================================= -->
                    <!-- ➕ SOUČET MATERIÁLU -->
                    <!-- ========================================================= -->
                    <!-- 🔴 ZMĚNA: StackPanel -> Grid -->
                    <Border Margin="0,10,0,0"
                            Padding="10"
                            BorderBrush="Gray"
                            BorderThickness="1">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Součet materiálu"
