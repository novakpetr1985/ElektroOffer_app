--BASEMATERIALS
-----------------------------------------------------------
--CREATE
CREATE TABLE BaseMaterials (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL UNIQUE
);

--MIGRATION
INSERT INTO BaseMaterials (Name)
SELECT DISTINCT TRIM(Material)
FROM PriceItems
WHERE Material IS NOT NULL;

SELECT * FROM BaseMaterials;

    -----------------------------------------------------------
    --PRICEMATRIX
    -----------------------------------------------------------
    --REFRESH
    INSERT INTO PriceMatrix (
        TaskId,
        BasePrice,
        Unit,
        Specification,
        MaterialCoef,
        PositionCoef
    )
    SELECT DISTINCT
        t.Id,
        p.BasePrice,
        p.Unit,
        p.Specification,
        p.MaterialCoef,
        p.PositionCoef
    FROM PriceItems p
    JOIN Tasks t ON TRIM(t.Name) = TRIM(p.Task)
    JOIN BaseMaterials b ON TRIM(b.Name) = TRIM(p.Material);

    SELECT * FROM PriceMatrix;

