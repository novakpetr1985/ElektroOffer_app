--POSITIONS
-----------------------------------------------------------
--CREATE
CREATE TABLE Positions (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL UNIQUE
);

--MIGRATION
INSERT INTO Positions (Name)
SELECT DISTINCT TRIM(Location)
FROM PriceItems
WHERE Location IS NOT NULL;

SELECT * FROM Positions;

    -----------------------------------------------------------
    --PRICEMATRIX
    -----------------------------------------------------------
    --DELETE
    DELETE FROM PriceMatrix;
    
    --REFRESH
    INSERT INTO PriceMatrix (
        TaskId,
        BasePrice,
        Unit,
        Specification,
        MaterialCoef,
        PositionCoef
    )
    SELECT DISTINCT
        t.Id,
        p.BasePrice,
        p.Unit,
        p.Specification,
        p.MaterialCoef,
        p.PositionCoef
    FROM PriceItems p
    JOIN Tasks t ON TRIM(t.Name) = TRIM(p.Task)
    JOIN BaseMaterials b ON TRIM(b.Name) = TRIM(p.Material)
    JOIN Positions pz ON TRIM(pz.Name) = TRIM(p.Location);

    SELECT * FROM PriceMatrix;

