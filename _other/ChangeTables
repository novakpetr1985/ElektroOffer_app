-----------------------------------------------------------
--TASK
-----------------------------------------------------------
--CREATE
CREATE TABLE Tasks (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL UNIQUE
);

--MIGRATION
INSERT INTO Tasks (Name)
SELECT DISTINCT TRIM(Task)
FROM PriceItems
WHERE Task IS NOT NULL;

SELECT * FROM Tasks;

    -----------------------------------------------------------
    --PRICEMATRIX
    -----------------------------------------------------------
    --ZALOŽENÍ
    CREATE TABLE PriceMatrix (
        Id INTEGER PRIMARY KEY AUTOINCREMENT,
        TaskId INTEGER NOT NULL,
        BasePrice REAL,
        Unit TEXT,
        Specification TEXT,
        MaterialCoef REAL,
        PositionCoef REAL,
        FOREIGN KEY (TaskId) REFERENCES Tasks(Id)
    );

    --PRICEMATRIX MIGRATION
    INSERT INTO PriceMatrix (
        TaskId,
        BasePrice,
        Unit,
        Specification,
        MaterialCoef,
        PositionCoef
    )
    SELECT DISTINCT
        t.Id,
        p.BasePrice,
        p.Unit,
        p.Specification,
        p.MaterialCoef,
        p.PositionCoef
    FROM PriceItems p
    JOIN Tasks t ON TRIM(t.Name) = TRIM(p.Task);

    SELECT * FROM PriceMatrix;

