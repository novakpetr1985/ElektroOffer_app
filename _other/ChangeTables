--SPECIFICATIONS
-----------------------------------------------------------
--CREATE
CREATE TABLE Specifications (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL UNIQUE
);

--MIGRATION
INSERT INTO Specifications (Name)
SELECT DISTINCT TRIM(Specification)
FROM PriceItems
WHERE Specification IS NOT NULL;

SELECT * FROM Specifications;

    -----------------------------------------------------------
    --PRICEMATRIX
    -----------------------------------------------------------
    --DELETE
    DELETE FROM PriceMatrix;
    
    --REFRESH
    INSERT INTO PriceMatrix (
        TaskId,
        BasePrice,
        Unit,
        Specification,
        MaterialCoef,
        PositionCoef
    )
    SELECT DISTINCT
        t.Id,
        p.BasePrice,
        p.Unit,
        p.Specification,
        p.MaterialCoef,
        p.PositionCoef
    FROM PriceItems p
    JOIN Tasks t ON TRIM(t.Name) = TRIM(p.Task)
    JOIN BaseMaterials b ON TRIM(b.Name) = TRIM(p.Material)
    JOIN Positions pz ON TRIM(pz.Name) = TRIM(p.Location)
    JOIN Specifications s ON TRIM(s.Name) = TRIM(p.Specification);

    SELECT * FROM PriceMatrix;

