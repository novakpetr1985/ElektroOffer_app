--TASKS
CREATE TABLE Tasks (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL,
    BasePrice REAL NOT NULL,
    Unit TEXT NOT NULL
);


--BASEMATERIALS
CREATE TABLE BaseMaterials (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL,
    Coef REAL NOT NULL
);


--POSITIONS
CREATE TABLE Positions (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    Name TEXT NOT NULL,
    Coef REAL NOT NULL
);


--SPECIFICATIONS
CREATE TABLE Specifications (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    TaskId INTEGER NOT NULL,
    Name TEXT NOT NULL,

    FOREIGN KEY (TaskId) REFERENCES Tasks(Id)
);


--PRICE MATRIX (HLAVNÍ LOGIKA)
CREATE TABLE PriceMatrix (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,

    TaskId INTEGER NOT NULL,
    MaterialId INTEGER NOT NULL,
    PositionId INTEGER NOT NULL,

    IsActive INTEGER DEFAULT 1,

    FOREIGN KEY (TaskId) REFERENCES Tasks(Id),
    FOREIGN KEY (MaterialId) REFERENCES Materials(Id),
    FOREIGN KEY (PositionId) REFERENCES Positions(Id)
);

--NEPOUŽITO, TABULKA STÁLE EXITUJE
--PRICEITEMS BACKUP
CREATE TABLE PriceItems (
    Id INTEGER PRIMARY KEY AUTOINCREMENT,
    BasePrice REAL,
    Unit TEXT,
    Task TEXT,
    Specification TEXT,
    Material TEXT,
    Location TEXT,
    MaterialCoef REAL,
    PositionCoef REAL
);