<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <!-- Jediný zdroj vizuálních hodnot pro WPF, tisk a PDF. -->

    <!-- Color primitives -->
    <Color x:Key="Color.Background">#F4F6F8</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceAlt">#EEF2F6</Color>
    <Color x:Key="Color.Border">#D6DDE6</Color>
    <Color x:Key="Color.Text">#1F2937</Color>
    <Color x:Key="Color.TextMuted">#667085</Color>
    <Color x:Key="Color.TextDisabled">#7B8794</Color>
    <Color x:Key="Color.Accent">#2563EB</Color>
    <Color x:Key="Color.AccentHover">#1D4ED8</Color>
    <Color x:Key="Color.OnAccent">#FFFFFF</Color>
    <Color x:Key="Color.Danger">#DC2626</Color>
    <Color x:Key="Color.Success">#15803D</Color>
    <Color x:Key="Color.Warning">#B91C1C</Color>
    <Color x:Key="Color.Dark.Background">#202020</Color>
    <Color x:Key="Color.Dark.Surface">#2B2B2B</Color>
    <Color x:Key="Color.Dark.SurfaceAlt">#383838</Color>
    <Color x:Key="Color.Dark.Border">#5A5A5A</Color>
    <Color x:Key="Color.Dark.Text">#F3F3F3</Color>
    <Color x:Key="Color.Dark.TextMuted">#C8C8C8</Color>
    <Color x:Key="Color.Dark.Accent">#1E5AA8</Color>
    <Color x:Key="Color.Dark.AccentHover">#164A8A</Color>
    <Color x:Key="Color.Dark.Danger">#B3261E</Color>
    <Color x:Key="Color.Dark.Success">#57A64A</Color>
    <Color x:Key="Color.Dark.Warning">#F1707A</Color>

    <!-- Typography -->
    <FontFamily x:Key="Typography.FontFamily.Ui">Segoe UI</FontFamily>
    <FontFamily x:Key="Typography.FontFamily.Document">Arial</FontFamily>
    <sys:Double x:Key="Typography.FontSize.Caption">12</sys:Double>
    <sys:Double x:Key="Typography.FontSize.Body">13</sys:Double>
    <sys:Double x:Key="Typography.FontSize.Label">14</sys:Double>
    <sys:Double x:Key="Typography.FontSize.Subtitle">16</sys:Double>
    <sys:Double x:Key="Typography.FontSize.Title">20</sys:Double>
    <sys:Double x:Key="Typography.FontSize.Display">26</sys:Double>
    <sys:Double x:Key="Typography.FontSize.Document">10</sys:Double>
    <FontWeight x:Key="Typography.FontWeight.Regular">Normal</FontWeight>
    <FontWeight x:Key="Typography.FontWeight.Medium">SemiBold</FontWeight>
    <FontWeight x:Key="Typography.FontWeight.Bold">Bold</FontWeight>

    <!-- Spacing and sizing (4 px grid) -->
    <sys:Double x:Key="Space.0">0</sys:Double>
    <sys:Double x:Key="Space.1">4</sys:Double>
    <sys:Double x:Key="Space.2">8</sys:Double>
    <sys:Double x:Key="Space.3">12</sys:Double>
    <sys:Double x:Key="Space.4">16</sys:Double>
    <sys:Double x:Key="Space.5">20</sys:Double>
    <sys:Double x:Key="Space.6">24</sys:Double>
    <sys:Double x:Key="Space.8">32</sys:Double>
    <Thickness x:Key="Spacing.ControlPadding">8,4</Thickness>
    <Thickness x:Key="Spacing.InputPadding">4,2</Thickness>
    <Thickness x:Key="Spacing.GroupBoxPadding">8</Thickness>
    <Thickness x:Key="Spacing.CardPadding">16</Thickness>
    <Thickness x:Key="Spacing.PagePadding">20</Thickness>
    <Thickness x:Key="Spacing.DocumentPagePadding">50</Thickness>
    <sys:Double x:Key="Size.ControlHeight.Small">24</sys:Double>
    <sys:Double x:Key="Size.ControlHeight.Default">28</sys:Double>
    <sys:Double x:Key="Size.Icon.Small">16</sys:Double>
    <sys:Double x:Key="Size.Icon.Default">20</sys:Double>

    <!-- Shape, borders and elevation -->
    <CornerRadius x:Key="Radius.Small">4</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">6</CornerRadius>
    <CornerRadius x:Key="Radius.Large">8</CornerRadius>
    <Thickness x:Key="Border.Width.Default">1</Thickness>
    <DropShadowEffect x:Key="Shadow.Low" Color="#33000000" BlurRadius="8" ShadowDepth="2" Opacity="0.35"/>
    <DropShadowEffect x:Key="Shadow.Medium" Color="#40000000" BlurRadius="16" ShadowDepth="4" Opacity="0.4"/>

    <!-- Motion -->
    <Duration x:Key="Motion.Duration.Fast">0:0:0.10</Duration>
    <Duration x:Key="Motion.Duration.Normal">0:0:0.20</Duration>
    <Duration x:Key="Motion.Duration.Slow">0:0:0.35</Duration>
    <CubicEase x:Key="Motion.Easing.Standard" EasingMode="EaseInOut"/>
    <CubicEase x:Key="Motion.Easing.Exit" EasingMode="EaseIn"/>
</ResourceDictionary>
