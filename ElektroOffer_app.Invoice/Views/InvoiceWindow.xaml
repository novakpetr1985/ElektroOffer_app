<Window x:Class="ElektroOffer_app.Invoice.Views.InvoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ElektroOffer - Fakturace"
        Width="1100"
        Height="820"
        MinWidth="900"
        MinHeight="650">
    <DockPanel LastChildFill="True"
               Background="{DynamicResource AppBackgroundBrush}">
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Ulozit"
                        Command="{Binding SaveInvoiceCommand}"
                        Margin="2"/>
                <Button Content="Ulozit jako"
                        Command="{Binding SaveInvoiceAsCommand}"
                        Margin="2"/>
                <Button Content="Nacist"
                        Command="{Binding LoadInvoiceCommand}"
                        Margin="2"/>
                <Separator/>
                <Button Content="Ulozit do projektu"
                        Command="{Binding SaveToProjectCommand}"
                        Margin="2"/>
                <Separator/>
                <Button Content="Export Fakturoid JSON"
                        Command="{Binding ExportFakturoidJsonCommand}"
                        Margin="2"/>
                <Button Content="Export PDF"
                        Command="{Binding ExportPdfCommand}"
                        Margin="2"/>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource AppMutedTextBrush}"/>
            </StatusBarItem>
        </StatusBar>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource AppBackgroundBrush}">
            <Grid Margin="18"
                  Background="{DynamicResource AppBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Fakturace"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,14"/>

                <Grid Grid.Row="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Dodavatel">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Nazev" Margin="0,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Supplier.Name, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="1" Text="ICO" Margin="0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Supplier.RegistrationNo, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Row="1" Grid.Column="2"
                                    Content="Vyhledat"
                                    Command="{Binding LookupSupplierAresCommand}"
                                    Margin="6,0,0,0"/>
                            <TextBlock Grid.Row="2" Text="DIC" Margin="0,4"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Supplier.VatNo, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="3" Text="Ulice" Margin="0,4"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Supplier.Street, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="4" Text="Mesto" Margin="0,4"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Supplier.City, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="5" Text="PSC" Margin="0,4"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Supplier.Zip, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="6" Text="E-mail" Margin="0,4"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Supplier.Email, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="7" Text="Telefon" Margin="0,4"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Supplier.Phone, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="Odberatel">
                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Nazev" Margin="0,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Customer.Name, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="1" Text="ICO" Margin="0,4"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Customer.RegistrationNo, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Row="1" Grid.Column="2"
                                    Content="Vyhledat"
                                    Command="{Binding LookupCustomerAresCommand}"
                                    Margin="6,0,0,0"/>
                            <TextBlock Grid.Row="2" Text="DIC" Margin="0,4"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Customer.VatNo, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="3" Text="Ulice" Margin="0,4"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Customer.Street, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="4" Text="Mesto" Margin="0,4"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Customer.City, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="5" Text="PSC" Margin="0,4"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Customer.Zip, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="6" Text="E-mail" Margin="0,4"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Customer.Email, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Row="7" Text="Telefon" Margin="0,4"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Customer.Phone, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </GroupBox>
                </Grid>

                <GroupBox Grid.Row="2" Header="Udaje faktury" Margin="0,0,0,14">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Cislo" Margin="0,4"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Draft.Number, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Variabilni symbol" Margin="12,4,0,4"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Draft.VariableSymbol, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Splatnost dni" Margin="12,4,0,4"/>
                        <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding Draft.DueDays, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="1" Text="Poznamka" Margin="0,8,0,4"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="5"
                                 MinHeight="60"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Text="{Binding Draft.Note, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Row="3" Header="Polozky z detailniho rozpoctu">
                    <DataGrid ItemsSource="{Binding Lines}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              Margin="10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Typ" Binding="{Binding Type}" Width="90"/>
                            <DataGridTextColumn Header="Popis" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Mnozstvi" Binding="{Binding Quantity}" Width="90"/>
                            <DataGridTextColumn Header="MJ" Binding="{Binding UnitName}" Width="70"/>
                            <DataGridTextColumn Header="Cena / MJ před slevou" Binding="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="145"/>
                            <DataGridTextColumn Header="Před slevou" Binding="{Binding TotalPriceBeforeDiscount, StringFormat={}{0:N2}}" Width="110"/>
                            <DataGridTextColumn Header="Sleva %" Binding="{Binding DiscountPercent, StringFormat={}{0:N0}}" Width="75"/>
                            <DataGridTextColumn Header="Sleva Kč" Binding="{Binding DiscountAmount, StringFormat={}{0:N2}}" Width="90"/>
                            <DataGridTextColumn Header="DPH %" Binding="{Binding VatRate}" Width="70"/>
                            <DataGridTextColumn Header="Po slevě" Binding="{Binding TotalPrice, StringFormat={}{0:N2}}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <TextBlock Grid.Row="4"
                           Text="{Binding Total, StringFormat=Celkem: {0:N2} Kc}"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"
                           Margin="0,14,0,0"/>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
